@model IEnumerable<KlawQ.Models.Favorite>
@{
    ViewData["Title"] = "My Bookmarks";
}
<link rel="stylesheet" href="/css/site.css" />
<div style="max-width:1100px;margin:28px auto">
    <h2>My Bookmarks</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:18px;margin-top:18px">
        @foreach(var f in Model ?? Enumerable.Empty<KlawQ.Models.Favorite>()){
            <div style="background:#fff;padding:12px;border-radius:10px;box-shadow:0 6px 12px rgba(0,0,0,.06)">
                <img src="@f.Product?.Product_Image" style="width:100%;height:160px;object-fit:cover;border-radius:8px" />
                <h4 style="margin:8px 0">@f.Product?.Product_Name</h4>
                <p style="color:#7a5046;font-size:13px">@f.Product?.Product_Description</p>
            </div>
        }
    </div>
</div>