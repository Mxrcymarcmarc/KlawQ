@model OrderStartViewModel

@{
    ViewData["Title"] = "Order Summary";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Shadows+Into+Light+Two&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/checkout-forms.css" />
}

<div class="form-wrapper">
    <div class="form-container" style="max-width:650px;">

        <div class="page-header">
            <h1 class="page-title"><i class="fas fa-shopping-bag title-icon"></i> Order Summary</h1>
            <p class="page-subtitle">Review your selected press-on designs and quantities before checking out.</p>
        </div>

        <div class="section-box">
            <h2 class="section-title"><i class="fas fa-list"></i> Selected Designs</h2>
            
            @if (Model.Products?.Count > 0)
            {
                <div style="display:flex; flex-direction:column; gap:1.2rem;">
                    @foreach (var product in Model.Products)
                    {
                        var imgUrl = product.Product_Image as string;
                        if (string.IsNullOrWhiteSpace(imgUrl)) imgUrl = Url.Content("~/images/placeholder.png");
                        else if (imgUrl.StartsWith("~")) imgUrl = Url.Content(imgUrl);
                        else if (!imgUrl.StartsWith("/")) imgUrl = Url.Content("~/" + imgUrl.TrimStart('/'));
                        else imgUrl = Url.Content(imgUrl);

                        var qty = Model.ProductQuantities.ContainsKey(product.ProductID) ? Model.ProductQuantities[product.ProductID] : 1;

                        <div style="display:flex; gap:1.2rem; align-items:center; padding-bottom:1rem; border-bottom:1px solid #fce4ec; margin-bottom: 0.5rem;">
                            <div style="width:80px; height:80px; border-radius:8px; overflow:hidden; border:2px solid var(--border-pink); flex-shrink:0;">
                                <img src="@imgUrl" alt="@product.Product_Name" style="width:100%; height:100%; object-fit:cover;" />
                            </div>
                            <div style="flex:1;">
                                <div style="font-weight:600; font-size:1.1rem; color:var(--text-brown); margin-bottom:0.25rem;">@product.Product_Name</div>
                                <div style="display:flex; justify-content:space-between; align-items:center;">
                                    <div style="color:var(--text-light); font-size:0.9rem;">₱@product.Product_Price.ToString("0.00") × @qty</div>
                                    <div style="font-weight:700; color:var(--text-brown); font-size:1.1rem;">₱@((product.Product_Price * qty).ToString("0.00"))</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p style="text-align:center; color:var(--text-light); margin:20px 0;">No items found in your selection.</p>
            }
        </div>

        <form method="get" action="/Order/CheckoutStandard">
            @foreach (var p in Model.Products ?? new List<Products>())
            {
                <input type="hidden" name="productIds" value="@p.ProductID" />
                <input type="hidden" name="qtys" value="@(Model.ProductQuantities.ContainsKey(p.ProductID) ? Model.ProductQuantities[p.ProductID] : 1)" />
            }

            <!-- Total Box -->
            <div class="info-alert" style="margin-top:1.5rem; background:#fffafb; border:2px solid var(--border-pink);">
                <div style="display:flex; justify-content:space-between; margin-bottom:0.6rem; font-size:1rem; color:var(--text-light); font-weight: 500;">
                    <span>Subtotal</span>
                    <span>₱@((Model.Products?.Sum(p => p.Product_Price * (Model.ProductQuantities.ContainsKey(p.ProductID) ? Model.ProductQuantities[p.ProductID] : 1)) ?? 0m).ToString("0.00"))</span>
                </div>
                <div style="display:flex; justify-content:space-between; font-weight:700; font-size:1.25rem; color:var(--text-brown); border-top:1px dashed var(--border-pink); padding-top:0.6rem;">
                    <span>Total Amount</span>
                    <span>₱@((Model.Products?.Sum(p => p.Product_Price * (Model.ProductQuantities.ContainsKey(p.ProductID) ? Model.ProductQuantities[p.ProductID] : 1)) ?? 0m).ToString("0.00"))</span>
                </div>
            </div>

            <!-- Action Buttons -->
            <div style="display:flex; gap:1.2rem; margin-top:2rem;">
                <a href="javascript:history.back()" class="btn-submit" style="background:#cccccc; color:#555555; text-decoration:none; box-shadow:none; flex:1; text-align:center; padding:1.2rem 0; display:inline-block; border-radius:30px;">Back</a>
                <button type="submit" class="btn-submit" style="flex:2; padding:1.2rem 0;">Proceed to Checkout</button>
            </div>
        </form>

    </div>
</div>
