@model KlawQ.Models.OrderStartViewModel
@{
    ViewData["Title"] = "Custom Order Sizing";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Shadows+Into+Light+Two&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/checkout-forms.css" />
}

<div class="form-wrapper">
    <div class="form-container">

        <div class="page-header">
            <h1 class="page-title"><i class="fas fa-paint-brush title-icon"></i> Custom Design Details</h1>
            <p class="page-subtitle">Provide your inspiration and sizing to complete your custom request.</p>
        </div>

        <form action="/Order/CheckoutCustom" method="post" enctype="multipart/form-data" class="grid-layout">
            @Html.AntiForgeryToken()

            @* pass product ids *@
            @{ var prods = Model?.Products ?? Enumerable.Empty<KlawQ.Models.Products>(); }
            @if (prods.Any())
            {
                foreach (var p in prods)
                {
                    <input type="hidden" name="ProductIds" value="@p.ProductID" />
                }
            }

            <div class="grid-col">
                <div class="section-box">
                    <h2 class="section-title"><i class="far fa-user"></i> Your Information</h2>

                    <div class="form-group">
                        <label>Full Name *</label>
                        <input type="text" name="FullName" required value="@(Model?.Submit?.FullName ?? String.Empty)" />
                    </div>

                    <div class="form-group">
                        <label>Email *</label>
                        <input type="email" name="Email" required value="@(Model?.Submit?.Email ?? String.Empty)" />
                    </div>

                    <div class="form-group">
                        <label>Phone *</label>
                        <input type="tel" name="ContactNumber" required value="@(Model?.Submit?.ContactNumber ?? String.Empty)" />
                    </div>

                    <div class="form-group">
                        <label>Social (IG/FB) *</label>
                        <input type="text" name="SocialAccount" required value="@(Model?.Submit?.SocialAccount ?? String.Empty)" />
                    </div>

                    <div class="form-group">
                        <label>Delivery Address *</label>
                        <input type="text" name="DeliveryLocation" required value="@(Model?.Submit?.DeliveryLocation ?? String.Empty)" />
                    </div>

                    <div class="form-group">
                        <label>Delivery Method *</label>
                        <select name="DeliveryMethod" required>
                            <option value="">Select delivery method</option>
                            <option value="Self-Collect">Self-Collect</option>
                            <option value="Courier">Courier</option>
                        </select>
                    </div>


                </div>

                <div class="section-box highlight-box">
                    <h2 class="section-title"><i class="far fa-images"></i> Design Inspiration</h2>
                    <div class="form-group">
                        <label>Upload Your Inspiration Images *</label>
                        <div class="upload-area inspiration-upload">
                            <i class="fas fa-camera retro-camera" id="upload-icon-insp"></i>
                            <h4 id="upload-status-text-insp">Click to upload inspiration</h4>
                            <input type="file" name="InspirationImages" accept="image/png, image/jpeg, image/jpg" multiple required />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Design Notes & Ideas *</label>
                        <textarea name="DesignNotes" rows="4" required>@((Model?.Submit as KlawQ.Models.CustomOrderSubmitModel)?.DesignNotes ?? String.Empty)</textarea>
                    </div>
                </div>
            </div>

            <div class="grid-col">
                <div class="section-box sizing-guide-box">
                    <h2 class="section-title"><i class="fas fa-hand-paper"></i> Nail Sizing</h2>
                    <div class="info-alert">
                        <p><strong>Bird's Eye View Photo:</strong> Lay your fingers flat beside a <strong>1 or 5 peso coin</strong> and take a photo from directly above.</p>
                    </div>

                    <div class="reference-photos">
                        <div class="ref-card correct">
                            <img src="~/images/right1.jpg" alt="Correct" class="ref-img" />
                            <p class="ref-label"><i class="fas fa-check"></i> Correct Angle</p>
                        </div>
                        <div class="ref-card incorrect">
                            <img src="~/images/wrong1.jpg" alt="Avoid" class="ref-img" />
                            <p class="ref-label"><i class="fas fa-times"></i> Avoid Angle</p>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Upload Your Sizing Photo *</label>
                        <div class="upload-area sizing-upload">
                            <i class="fas fa-upload retro-camera" id="upload-icon-hand"></i>
                            <h4 id="upload-status-text-hand">Click to upload sizing photo</h4>
                            <input type="file" name="HandPhoto" accept="image/png, image/jpeg, image/jpg" required />
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-submit"><i class="fas fa-paper-plane"></i> Submit Custom Request</button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Hand Sizing Photo Upload
            const handInput = document.querySelector('input[name="HandPhoto"]');
            const handStatus = document.getElementById('upload-status-text-hand');
            const handIcon = document.getElementById('upload-icon-hand');

            handInput.addEventListener('change', (e) => {
                const file = e.target.files[0];
                if (!file) return;

                const allowedExtensions = /(\.png|\.jpg|\.jpeg)$/i;
                if (!allowedExtensions.exec(file.name)) {
                    alert('Only .png, .jpg, and .jpeg files are allowed.');
                    handInput.value = '';
                    handStatus.innerHTML = "Click to upload sizing photo";
                    handIcon.className = 'fas fa-upload retro-camera';
                    return;
                }

                handStatus.innerHTML = `Attached: <strong>${file.name}</strong> <span id="clear-hand-btn" style="color: #d32f2f; cursor: pointer; margin-left: 8px; font-weight: bold; font-size: 16px;">✕</span>`;
                handIcon.className = 'fas fa-image retro-camera';
            });

            handStatus.addEventListener('click', (e) => {
                if (e.target.id === 'clear-hand-btn') {
                    e.preventDefault();
                    e.stopPropagation();
                    handInput.value = '';
                    handStatus.innerHTML = "Click to upload sizing photo";
                    handIcon.className = 'fas fa-upload retro-camera';
                }
            });

            const handArea = document.querySelector('.sizing-upload');
            handArea.addEventListener('dragover', (e) => {
                e.preventDefault();
                handArea.style.backgroundColor = 'var(--accent-pink)';
            });
            handArea.addEventListener('dragleave', () => {
                handArea.style.backgroundColor = '';
            });
            handArea.addEventListener('drop', (e) => {
                e.preventDefault();
                handArea.style.backgroundColor = '';
                const files = e.dataTransfer.files;
                if (files && files.length > 0) {
                    handInput.files = files;
                    handInput.dispatchEvent(new Event('change'));
                }
            });

            // Inspiration Images Upload (Multiple)
            const inspInput = document.querySelector('input[name="InspirationImages"]');
            const inspStatus = document.getElementById('upload-status-text-insp');
            const inspIcon = document.getElementById('upload-icon-insp');

            inspInput.addEventListener('change', (e) => {
                const files = e.target.files;
                if (!files || files.length === 0) return;

                const allowedExtensions = /(\.png|\.jpg|\.jpeg)$/i;
                for (let i = 0; i < files.length; i++) {
                    if (!allowedExtensions.exec(files[i].name)) {
                        alert('Only .png, .jpg, and .jpeg files are allowed. Invalid file: ' + files[i].name);
                        inspInput.value = '';
                        inspStatus.innerHTML = "Click to upload inspiration";
                        inspIcon.className = 'fas fa-camera retro-camera';
                        return;
                    }
                }

                let displayName = files.length === 1 ? files[0].name : `${files.length} images`;
                inspStatus.innerHTML = `Attached: <strong>${displayName}</strong> <span id="clear-insp-btn" style="color: #d32f2f; cursor: pointer; margin-left: 8px; font-weight: bold; font-size: 16px;">✕</span>`;
                inspIcon.className = 'fas fa-image retro-camera';
            });

            inspStatus.addEventListener('click', (e) => {
                if (e.target.id === 'clear-insp-btn') {
                    e.preventDefault();
                    e.stopPropagation();
                    inspInput.value = '';
                    inspStatus.innerHTML = "Click to upload inspiration";
                    inspIcon.className = 'fas fa-camera retro-camera';
                }
            });

            const inspArea = document.querySelector('.inspiration-upload');
            inspArea.addEventListener('dragover', (e) => {
                e.preventDefault();
                inspArea.style.backgroundColor = 'var(--accent-pink)';
            });
            inspArea.addEventListener('dragleave', () => {
                inspArea.style.backgroundColor = '';
            });
            inspArea.addEventListener('drop', (e) => {
                e.preventDefault();
                inspArea.style.backgroundColor = '';
                const files = e.dataTransfer.files;
                if (files && files.length > 0) {
                    inspInput.files = files;
                    inspInput.dispatchEvent(new Event('change'));
                }
            });
        });
    </script>
}
