@model KlawQ.Models.OrderStartViewModel
@{
    ViewData["Title"] = "Finalize Order";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Shadows+Into+Light+Two&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/checkout-forms.css" />
}

<div class="form-wrapper">
    <div class="form-container">

        <div class="page-header">
            <h1 class="page-title"><i class="fas fa-check-circle title-icon"></i> Finalize Order</h1>
            <p class="page-subtitle">Provide your sizing photo and delivery details to complete your order.</p>
        </div>

        <form asp-controller="Order" asp-action="CheckoutStandard" method="post" enctype="multipart/form-data" class="grid-layout">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="text-danger" style="color: #d32f2f; font-weight: 600; grid-column: 1 / -1; background: #ffebee; padding: 15px; border-radius: 12px; margin-bottom: 20px; border: 1px solid #f4c7c7;"></div>
            }

            @* Product IDs and Quantities passed from the checkout staging timeline *@
            @if (Model?.Products != null && Model.Products.Any())
            {
                foreach (var p in Model.Products)
                {
                    <input type="hidden" name="ProductIds" value="@p.ProductID" />
                    <input type="hidden" name="Quantities" value="@(Model.ProductQuantities.ContainsKey(p.ProductID) ? Model.ProductQuantities[p.ProductID] : 1)" />
                }
            }

            <input type="hidden" name="DeliveryMethod" value="Standard Delivery" />
            <input type="hidden" name="PaymentMethod" value="PayMongo" />

            <div class="grid-col">
                <div class="section-box">
                    <h2 class="section-title"><i class="far fa-user"></i> Your Information</h2>
                    <div class="form-group"><label>Full Name *</label><input type="text" name="FullName" required value="@Model?.Submit?.FullName"></div>
                    <div class="form-group"><label>Email *</label><input type="email" name="Email" required value="@Model?.Submit?.Email"></div>
                    <div class="form-group"><label>Phone *</label><input type="tel" name="ContactNumber" required value="@Model?.Submit?.ContactNumber"></div>
                    <div class="form-group"><label>Social (IG/FB) *</label><input type="text" name="SocialAccount" required value="@Model?.Submit?.SocialAccount"></div>
                    <div class="form-group"><label>Delivery Address *</label><input type="text" name="DeliveryLocation" required value="@Model?.Submit?.DeliveryLocation"></div>

                    @* Displays your selected press-on accessory design miniatures *@
                    @if (Model?.Products != null && Model.Products.Any())
                    {
                        <div class="form-group" style="margin-top:12px;">
                            <label>Designs</label>
                            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;">
                                @foreach (var it in Model.Products)
                                {
                                    var pImg = it.Product_Image as string;
                                    if (string.IsNullOrWhiteSpace(pImg)) pImg = Url.Content("~/images/placeholder.png");
                                    else if (pImg.StartsWith("~")) pImg = Url.Content(pImg);
                                    else if (!pImg.StartsWith("/")) pImg = Url.Content("~/" + pImg.TrimStart('/'));
                                    else pImg = Url.Content(pImg);

                                    <div style="width:64px;height:64px;border-radius:6px;overflow:hidden;border:2px solid #fde6ea;">
                                        <img src="@pImg" alt="@it.Product_Name" style="width:100%;height:100%;object-fit:cover;" />
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="grid-col">
                <div class="section-box sizing-guide-box">
                    <h2 class="section-title"><i class="fas fa-hand-paper"></i> Nail Sizing</h2>
                    <div class="info-alert">
                        <p><strong>Bird's Eye View Photo:</strong> Lay your fingers flat beside a <strong>1 or 5 peso coin</strong> and take a photo from directly above.</p>
                    </div>

                    <div class="reference-photos">
                        <div class="ref-card correct">
                            <img src="@Url.Content("~/images/right1.jpg")" alt="Correct" class="ref-img">
                            <p class="ref-label"><i class="fas fa-check"></i> Correct Angle</p>
                        </div>
                        <div class="ref-card incorrect">
                            <img src="@Url.Content("~/images/wrong1.jpg")" alt="Avoid" class="ref-img">
                            <p class="ref-label"><i class="fas fa-times"></i> Avoid Angle</p>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Upload Your Sizing Photo *</label>
                        <div class="upload-area sizing-upload">
                            <i class="fas fa-upload retro-camera" id="upload-icon-hand"></i>
                            <h4 id="upload-status-text-hand">Click to upload sizing photo</h4>
                            <input type="file" name="HandPhoto" accept="image/png, image/jpeg, image/jpg" required>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid-col">
                <button type="submit" class="btn-submit"><i class="fas fa-paper-plane"></i> Place Order</button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const fileInput = document.querySelector('input[name="HandPhoto"]');
            const statusText = document.getElementById('upload-status-text-hand');
            const uploadIcon = document.getElementById('upload-icon-hand');

            fileInput.addEventListener('change', (e) => {
                const file = e.target.files[0];
                if (!file) return;

                const allowedExtensions = /(\.png|\.jpg|\.jpeg)$/i;
                if (!allowedExtensions.exec(file.name)) {
                    alert('Only .png, .jpg, and .jpeg files are allowed.');
                    fileInput.value = '';
                    statusText.innerHTML = "Click to upload sizing photo";
                    uploadIcon.className = 'fas fa-upload retro-camera';
                    return;
                }

                statusText.innerHTML = `Attached: <strong>${file.name}</strong> <span id="clear-hand-btn" style="color: #d32f2f; cursor: pointer; margin-left: 8px; font-weight: bold; font-size: 16px;">✕</span>`;
                uploadIcon.className = 'fas fa-image retro-camera';
            });

            statusText.addEventListener('click', (e) => {
                if (e.target.id === 'clear-hand-btn') {
                    e.preventDefault();
                    e.stopPropagation();
                    fileInput.value = '';
                    statusText.innerHTML = "Click to upload sizing photo";
                    uploadIcon.className = 'fas fa-upload retro-camera';
                }
            });

            const uploadArea = document.querySelector('.sizing-upload');
            uploadArea.addEventListener('dragover', (e) => {
                e.preventDefault();
                uploadArea.style.backgroundColor = 'var(--accent-pink)';
            });
            uploadArea.addEventListener('dragleave', () => {
                uploadArea.style.backgroundColor = '';
            });
            uploadArea.addEventListener('drop', (e) => {
                e.preventDefault();
                uploadArea.style.backgroundColor = '';
                const files = e.dataTransfer.files;
                if (files && files.length > 0) {
                    fileInput.files = files;
                    fileInput.dispatchEvent(new Event('change'));
                }
            });
        });
    </script>
}