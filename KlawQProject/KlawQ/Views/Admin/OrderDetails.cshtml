@model KlawQ.Models.Order
@{
    ViewData["Title"] = "Order Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["NavbarMode"] = "admin";
    
    var statusClass = "status-confirmed";
    var statusText = "Pending";
    if (Model.Status.Equals("Confirmed", StringComparison.OrdinalIgnoreCase))
    {
        statusClass = "status-confirmed";
        statusText = "Confirmed";
    }
    else if (Model.Status.Equals("In Progress", StringComparison.OrdinalIgnoreCase))
    {
        statusClass = "status-progress";
        statusText = "In Progress";
    }
    else if (Model.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase))
    {
        statusClass = "status-completed";
        statusText = "Completed";
    }
    else if (Model.Status.Equals("Cancelled", StringComparison.OrdinalIgnoreCase))
    {
        statusClass = "";
        statusText = "Cancelled";
    }

    string designNotes = "";
    List<string> inspirations = new List<string>();
    bool isCustomApproved = Model.Order_Type == 'P' && !string.IsNullOrWhiteSpace(Model.Thumb_Photo) && Model.Thumb_Photo.TrimStart().StartsWith("{");
    if ((Model.Order_Type == 'C' || isCustomApproved) && !string.IsNullOrWhiteSpace(Model.Thumb_Photo))
    {
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(Model.Thumb_Photo);
            if (doc.RootElement.TryGetProperty("designNotes", out var dnProp))
            {
                designNotes = dnProp.GetString() ?? "";
            }
            if (doc.RootElement.TryGetProperty("inspirations", out var inspProp) && inspProp.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var element in inspProp.EnumerateArray())
                {
                    var base64 = element.GetString();
                    if (!string.IsNullOrWhiteSpace(base64))
                    {
                        inspirations.Add(base64);
                    }
                }
            }
        }
        catch { }
    }
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Shadows+Into+Light+Two&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    :root {
        --bg-pink: #fffafb;
        --panel-pink: #fcd8dd;
        --accent-pink: #fbc0c7;
        --brand-brown: #8b4b3b;
        --footer-brown: #6b4228;
        --cta-green: #88b04b;
        --font-brown: #8B5E34;
        --grey-inactive: #e8d0d2;
    }

    .order-view-body {
        background: var(--bg-pink);
        font-family: 'Montserrat', sans-serif;
        color: var(--font-brown);
        padding: 20px 0;
    }

    .order-wrap {
        max-width: 1100px;
        margin: 20px auto;
        padding: 0 20px;
        box-sizing: border-box;
    }

    .order-layout-grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 20px;
        align-items: start;
    }

    .order-layout-column {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    @@media (max-width: 900px) {
        .order-wrap {
            max-width: 620px;
        }
        .order-layout-grid {
            grid-template-columns: 1fr;
            gap: 16px;
        }
    }

    /* ── Card base ── */
    .card {
        background: #fff;
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 16px;
        box-shadow: 0 4px 20px rgba(139, 75, 59, 0.06);
        border: 1px solid var(--accent-pink);
    }

    /* ── Order Details header ── */
    .card-header-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 16px;
    }

    .card-title {
        font-family: 'Shadows Into Light Two', cursive;
        font-size: 28px;
        color: var(--font-brown);
        margin: 0;
    }

    .card-title i {
        font-size: 22px;
        margin-right: 6px;
        color: var(--cta-green);
    }

    .order-meta {
        font-size: 13px;
        color: #bbb;
        margin: 4px 0 0 0;
    }

    .badge-confirmed {
        background: #eaf4fd;
        color: #3a9bd5;
        border: 1px solid #c0dff5;
        border-radius: 20px;
        padding: 4px 14px;
        font-size: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
    }

    /* ── Timeline Track ── */
    .timeline-label {
        font-size: 14px;
        font-weight: 600;
        color: var(--font-brown);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .timeline-track {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
        margin-bottom: 8px;
    }

    .timeline-segment {
        height: 8px;
        border-radius: 4px;
        background: var(--grey-inactive);
        transition: background 0.3s ease;
    }

    .timeline-steps {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        margin-top: 6px;
    }

    .timeline-steps span {
        font-size: 11px;
        color: #bbb;
        background: transparent !important;
        display: inline-block;
    }

    /* Status Configs */
    .status-confirmed .seg-1 {
        background: var(--cta-green);
    }

    .status-confirmed .step-1 {
        color: var(--cta-green) !important;
        font-weight: 600;
    }

    .status-progress .seg-1,
    .status-progress .seg-2 {
        background: var(--cta-green);
    }

    .status-progress .step-1,
    .status-progress .step-2 {
        color: var(--cta-green) !important;
        font-weight: 600;
    }

    .status-completed .seg-1,
    .status-completed .seg-2,
    .status-completed .seg-3 {
        background: var(--cta-green);
    }

    .status-completed .step-1,
    .status-completed .step-2,
    .status-completed .step-3 {
        color: var(--cta-green) !important;
        font-weight: 600;
    }

    .estimated {
        font-size: 13px;
        color: #bbb;
        margin-top: 14px;
        margin-bottom: 0;
    }

    .estimated strong {
        color: var(--font-brown);
    }

    /* ── Headers ── */
    .section-title {
        font-family: 'Shadows Into Light Two', cursive;
        font-size: 22px;
        color: var(--font-brown);
        margin: 0 0 16px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .section-title i {
        color: var(--cta-green);
        font-size: 18px;
    }

    /* ── Uniform Input Field Layouts ── */
    .form-group {
        margin-bottom: 12px;
    }

    .info-label {
        font-size: 11px;
        color: #ccc;
        margin: 0 0 4px 4px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: block;
    }

    .input-icon-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-icon-wrap i {
        position: absolute;
        left: 14px;
        color: var(--accent-pink);
        font-size: 14px;
        width: 16px;
        text-align: center;
        pointer-events: none;
    }

    .form-input-display {
        width: 100%;
        background: #fff;
        border: 1px solid var(--accent-pink);
        border-radius: 10px;
        padding: 10px 12px 10px 40px;
        font-family: 'Montserrat', sans-serif;
        font-size: 13px;
        color: var(--font-brown);
        box-sizing: border-box;
    }

    .form-input-display:disabled {
        background: #fff;
        color: var(--font-brown);
        opacity: 1;
    }

    .form-input-display.bold-text {
        font-weight: 600;
        font-size: 14px;
    }

    /* ── Order Summary ── */
    .order-item-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 4px;
    }

    .order-item-name {
        font-size: 14px;
        font-weight: 600;
        color: var(--font-brown);
    }

    .order-item-price {
        font-size: 14px;
        font-weight: 600;
        color: var(--font-brown);
        text-align: right;
    }

    .order-item-meta {
        font-size: 11px;
        color: #bbb;
        margin-bottom: 12px;
    }

    .badge-size {
        background: var(--bg-pink);
        color: var(--cta-green);
        border: 1px solid var(--accent-pink);
        padding: 2px 8px;
        border-radius: 6px;
        font-weight: 600;
    }

    .divider-line {
        border: none;
        border-top: 1px solid var(--accent-pink);
        margin: 16px 0;
    }

    .total-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 16px;
        font-weight: 700;
        color: var(--font-brown);
    }

    .total-amount {
        color: var(--cta-green);
        font-size: 24px;
    }

    /* ── Special Notes Textarea ── */
    .notes-textarea {
        width: 100%;
        background: #fff;
        border: 1px solid var(--accent-pink);
        border-radius: 12px;
        padding: 14px 16px;
        font-family: 'Montserrat', sans-serif;
        font-size: 13px;
        color: var(--font-brown);
        min-height: 70px;
        resize: none;
        box-sizing: border-box;
    }

    .notes-textarea:disabled {
        background: #fff;
        opacity: 1;
    }

    /* ── Back button ── */
    .back-dash-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--font-brown);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
        transition: all 0.2s;
    }

    .back-dash-link:hover {
        color: var(--brand-brown);
        transform: translateX(-3px);
    }
</style>

<div class="order-view-body">
    <div class="order-wrap">
        <a href="/AdminOrders?status=All" class="back-dash-link">
            <i class="fas fa-arrow-left"></i> Back to Orders
        </a>

        <div class="order-layout-grid">
            <!-- Left Column -->
            <div class="order-layout-column main-col">
                <!-- Card 1 -->
                <div class="card @statusClass">
                    <div class="card-header-row">
                        <div>
                            <p class="card-title"><i class="fa-solid fa-box"></i> Order Details</p>
                            <p class="order-meta">Order No. ORD-@Model.OrderID</p>
                            <p class="order-meta">Placed on @Model.Order_Date.ToString("MM/dd/yyyy h:mm tt")</p>
                        </div>
                        @if (Model.Status.Equals("Cancelled", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge-cancelled" style="background: #fce8e6; color: #dc3545; border: 1px solid #fcd2cd; border-radius: 20px; padding: 4px 14px; font-size: 12px; font-weight: 600; display: inline-flex; align-items: center; gap: 5px; white-space: nowrap;"><i class="fas fa-times"></i> Cancelled</span>
                        }
                        else
                        {
                            <span class="badge-confirmed"><i class="fas fa-check"></i> @statusText</span>
                        }
                    </div>

                    <div class="timeline-label"><i class="fa-regular fa-clock"></i> Order Timeline</div>
                    <div class="timeline-track">
                        <div class="timeline-segment seg-1"></div>
                        <div class="timeline-segment seg-2"></div>
                        <div class="timeline-segment seg-3"></div>
                    </div>
                    <div class="timeline-steps">
                        <span class="step-1">Confirmed</span>
                        <span class="step-2" style="text-align: center;">In Progress</span>
                        <span class="step-3" style="text-align: right;">Completed</span>
                    </div>
                    @if (Model.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase))
                    {
                        <p class="estimated">Completed on: <strong>@Model.Order_Date.AddDays(3).ToString("MM/dd/yyyy")</strong></p>
                    }
                    else if (Model.Status.Equals("Cancelled", StringComparison.OrdinalIgnoreCase))
                    {
                        <p class="estimated">Cancelled on: <strong>@Model.Order_Date.AddDays(1).ToString("MM/dd/yyyy")</strong></p>
                    }
                    else
                    {
                        <p class="estimated">Estimated Completion: <strong>@Model.Order_Date.AddDays(7).ToString("MM/dd/yyyy")</strong></p>
                    }
                </div>

                <!-- Card 2 -->
                <div class="card">
                    <p class="section-title"><i class="fa-regular fa-user"></i> Customer Information</p>

                    <div class="form-group">
                        <label class="info-label">Name</label>
                        <div class="input-icon-wrap">
                            <i class="fa-regular fa-user"></i>
                            <input type="text" class="form-input-display bold-text" value="@Model.Full_Name" disabled />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="info-label">Email</label>
                        <div class="input-icon-wrap">
                            <i class="fa-regular fa-envelope"></i>
                            <input type="email" class="form-input-display" value="@ViewBag.UserEmail" disabled />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="info-label">Phone</label>
                        <div class="input-icon-wrap">
                            <i class="fa-solid fa-phone"></i>
                            <input type="text" class="form-input-display" value="@Model.Contact_Number" disabled />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="info-label">Social Account</label>
                        <div class="input-icon-wrap">
                            <i class="fa-solid fa-hashtag"></i>
                            <input type="text" class="form-input-display" value="@Model.Social_Account" disabled />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="info-label">Delivery Location</label>
                        <div class="input-icon-wrap">
                            <i class="fa-solid fa-location-dot"></i>
                            <input type="text" class="form-input-display" value="@Model.Delivery_Location" disabled />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="info-label">Delivery Method</label>
                        <div class="input-icon-wrap">
                            <i class="fa-solid fa-truck"></i>
                            <input type="text" class="form-input-display" value="@Model.Delivery_Method" disabled />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="info-label">Payment Method</label>
                        <div class="input-icon-wrap">
                            <i class="fa-solid fa-credit-card"></i>
                            <input type="text" class="form-input-display" value="@Model.Payment_Method" disabled />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column -->
            <div class="order-layout-column side-col">
                <!-- Card 3 -->
                <div class="card">
                    <p class="section-title"><i class="fa-solid fa-receipt"></i> Order Summary</p>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <div class="order-item-row">
                                <span class="order-item-name">@(item.Product?.Product_Name ?? "Press-On Set")</span>
                                <span class="order-item-price">₱@((item.Product?.Product_Price ?? 0).ToString("N2"))</span>
                            </div>
                            <div class="order-item-meta">Qty: @item.Quantity &nbsp;|&nbsp; <span class="badge-size">Size: @(Model.Order_Type == 'C' ? "Custom" : "Standard")</span></div>
                        }
                    }
                    else
                    {
                        <div class="order-item-row">
                            <span class="order-item-name">Custom Press-On Set Request</span>
                            <span class="order-item-price">₱150.00</span>
                        </div>
                        <div class="order-item-meta">Qty: 1 &nbsp;|&nbsp; <span class="badge-size">Size: Custom</span></div>
                    }
                    <hr class="divider-line" />
                    <div class="total-row">
                        <span>Total</span>
                        @{
                            var totalAmount = Model.Items != null && Model.Items.Any()
                                ? Model.Items.Sum(item => (item.Product?.Product_Price ?? 0) * item.Quantity)
                                : 150.00m;
                        }
                        <span class="total-amount">₱@totalAmount.ToString("N2")</span>
                    </div>
                </div>

                <!-- Card 4 -->
                @if (Model.Order_Type == 'C' || isCustomApproved)
                {
                    <div class="card">
                        <p class="section-title"><i class="fa-regular fa-star"></i> Special Notes & Design Details</p>
                        @if (!string.IsNullOrWhiteSpace(designNotes))
                        {
                            <textarea class="notes-textarea" disabled>@designNotes</textarea>
                        }
                        else
                        {
                            <p style="font-size: 13px; color: #aaa; margin: 0 0 10px 0;">No custom design notes provided.</p>
                        }

                        @if (!string.IsNullOrWhiteSpace(Model.Hand_Photo))
                        {
                            <div style="margin-top: 15px;">
                                <p class="info-label" style="margin-bottom: 8px;">Hand Sizing Photo</p>
                                <img src="@Model.Hand_Photo" style="max-width: 100%; max-height: 250px; border-radius: 8px; border: 1px solid var(--accent-pink);" />
                            </div>
                        }

                        @if (inspirations.Any())
                        {
                            <div style="margin-top: 15px;">
                                <p class="info-label" style="margin-bottom: 8px;">Inspiration Images</p>
                                <div style="display: flex; gap: 10px; overflow-x: auto; padding-bottom: 8px;">
                                    @foreach (var img in inspirations)
                                    {
                                        <img src="@img" style="max-height: 150px; border-radius: 8px; border: 1px solid var(--accent-pink);" />
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="card">
                        <p class="section-title"><i class="fa-regular fa-star"></i> Special Notes</p>
                        @if (!string.IsNullOrWhiteSpace(Model.Hand_Photo))
                        {
                            <div style="margin-bottom: 15px;">
                                <p class="info-label" style="margin-bottom: 8px;">Hand Sizing Photo</p>
                                <img src="@Model.Hand_Photo" style="max-width: 100%; max-height: 250px; border-radius: 8px; border: 1px solid var(--accent-pink);" />
                            </div>
                        }
                        <textarea class="notes-textarea" disabled>Standard Press-On order. Sizing: Standard.</textarea>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
