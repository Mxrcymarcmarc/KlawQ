@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    ViewData["NavbarMode"] = "admin";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Shadows+Into+Light+Two&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin-dashboard.css" />
}

<div class="container">
    <div class="page-title-section">
        <h1 class="page-title"><i class="fas fa-shield-alt"></i> Admin Dashboard</h1>
        <p class="page-subtitle">Manage your nail studio at a glance</p>
    </div>

    <div class="admin-control-bar">
        <button class="action-bar-btn" onclick="location.href='@Url.Action("PortfolioManager", "Admin")'">
            <i class="fas fa-box"></i> <span>Manage Portfolio</span>
        </button>
        <button class="action-bar-btn" onclick="location.href='@Url.Action("ConfigureSlots", "Admin")'">
            <i class="far fa-clock"></i> <span>Configure Slots</span>
        </button>
        <button class="action-bar-btn" onclick="location.href='@Url.Action("ManageAppointments", "Admin")'">
            <i class="far fa-calendar-check"></i> <span>Manage Appointments</span>
        </button>
        <button class="action-bar-btn" onclick="location.href='@Url.Action("Index", "AdminOrders", new { status = "All" })'">
            <i class="fas fa-receipt"></i> <span>Manage Orders</span>
        </button>
        <button class="action-bar-btn" onclick="location.href='@Url.Action("Index", "AdminCancellations", "Admin")'">
            <i class="far fa-calendar-times"></i> <span>Cancellations</span>
        </button>
        <button class="action-bar-btn" onclick="location.href='@Url.Action("ViewPortfolio", "Admin")'">
            <i class="far fa-eye"></i> <span>Public Gallery</span>
        </button>
    </div>

    <div class="metrics-strip">
        <div class="metric-strip-card revenue-card">
            <span class="card-label">TOTAL REVENUE</span>
            <h2 class="metric-val">₱@(((decimal)(ViewData["TotalRevenue"] ?? 0m)).ToString("N2"))</h2>
            <span class="card-subtext">Completed orders</span>
        </div>

        <div class="metric-strip-card clickable-metric" onclick="location.href='/AdminOrders?status=All'">
            <div class="metric-strip-header">
                <i class="fas fa-cube text-green"></i>
                <span class="card-label">TOTAL ORDERS</span>
            </div>
            <h2 class="metric-val">@(ViewData["TotalOrdersCount"] ?? 0)</h2>
        </div>

        <div class="metric-strip-card clickable-metric" onclick="location.href='/AdminOrders?status=Pending'">
            <div class="metric-strip-header">
                <i class="far fa-clock text-yellow"></i>
                <span class="card-label">PENDING ORDERS</span>
            </div>
            <h2 class="metric-val">@(ViewData["PendingOrdersCount"] ?? 0)</h2>
        </div>

        <div class="metric-strip-card clickable-metric" onclick="location.href='/AdminOrders?status=Completed'">
            <div class="metric-strip-header">
                <i class="far fa-check-circle text-green"></i>
                <span class="card-label">COMPLETED</span>
            </div>
            <h2 class="metric-val">@(ViewData["CompletedOrdersCount"] ?? 0)</h2>
        </div>

        <div class="metric-strip-card">
            <div class="metric-strip-header">
                <i class="far fa-calendar-alt text-muted"></i>
                <span class="card-label">THIS WEEK</span>
            </div>
            <h2 class="metric-val">@(ViewData["ThisWeekBookingsCount"] ?? 0)</h2>
        </div>
    </div>

    <div class="section-box">
    <div class="section-header">
        <h2><i class="fas fa-star"></i> Top Services</h2>
        </div>

        <div class="services-grid">
            <!-- Service Item 1 -->
            <div class="service-row">
                <div class="rank-badge">#1</div>
                <h4 class="service-name">Custom Nail Art Design</h4>
                <span class="service-bookings">2 bookings</span>
                <p class="service-price">₱1,020.00</p>
            </div>

            <!-- Service Item 2 -->
            <div class="service-row">
                <div class="rank-badge">#2</div>
                <h4 class="service-name">Gel Manicure</h4>
                <span class="service-bookings">8 bookings</span>
                <p class="service-price">₱900.00</p>
            </div>
        </div>
    </div>

    <div class="section-box">
        <div class="section-header">
            <h2><i class="fas fa-user-friends"></i> Recent Orders</h2>
            <span class="badge-total">@(ViewData["TotalOrdersCount"] ?? 0) total</span>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Order #</th>
                        <th>Customer</th>
                        <th>Delivery Method</th>
                        <th>Payment Method</th>
                        <th>Contact Number</th>
                        <th>Type</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>D-1</td>
                        <td class="customer-info">Juan Dela Cruz<p>User Contact Details</p></td>
                        <td>Standard Delivery</td>
                        <td>GCash</td>
                        <td>09123456789</td>
                        <td><span class="badge">💅 Press-On</span></td>
                        <td>2026-06-16</td>
                        <td><span class="status status-pending"><i class="far fa-clock"></i> Pending</span></td>
                        <td>
                            <button type="button" class="btn-action" onclick="location.href='@Url.Action("Index", "AdminOrders", new { status = "Pending" })'">
                                <i class="fas fa-pencil-alt"></i>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>