@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    ViewData["NavbarMode"] = "admin";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Shadows+Into+Light+Two&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin-dashboard.css" />
}

<div class="container">
    <div class="page-title-section">
        <h1 class="page-title"><i class="fas fa-shield-alt"></i> Admin Dashboard</h1>
        <p class="page-subtitle">Manage your nail studio at a glance</p>
    </div>

    <div class="cards-grid">
        <div class="card">
            <div class="card-icon"><i class="fas fa-box"></i></div>
            <div class="card-content">
                <h3>Manage Portfolio</h3>
                <p>Add/edit nail works</p>
            </div>
            <div class="card-actions">
                <button type="button" class="btn" onclick="location.href='@Url.Action("PortfolioManager", "Admin")'">Manage Portfolio</button>
            </div>
        </div>
        <div class="card">
            <div class="card-icon"><i class="far fa-calendar-times"></i></div>
            <div class="card-content">
                <h3>View Order Cancellations</h3>
                <p>Check cancellations</p>
            </div>
        </div>
        <div class="card">
            <div class="card-icon"><i class="far fa-eye"></i></div>
            <div class="card-content">
                <h3>View Portfolio</h3>
                <p>Public gallery view</p>
            </div>
        </div>
    </div>

    <div class="cards-grid">
        <div class="card revenue-card">
            <div class="card-icon">₱</div>
            <h3>Total Revenue</h3>
            <h2>₱@(((decimal)(ViewData["TotalRevenue"] ?? 0m)).ToString("N2"))</h2>
            <p>From completed orders</p>
        </div>

        <div class="card stat-card" style="cursor: pointer;" onclick="location.href='/AdminOrders?status=All'">
            <div class="card-icon"><i class="fas fa-cube"></i></div>
            <h3>Total Orders</h3>
            <h2>@(ViewData["TotalOrdersCount"] ?? 0)</h2>
            <p>All Time</p>
        </div>

        <div class="card stat-card" style="cursor: pointer;" onclick="location.href='/AdminOrders?status=Pending'">
            <div class="card-icon"><i class="far fa-clock"></i></div>
            <h3>Pending Orders</h3>
            <h2>@(ViewData["PendingOrdersCount"] ?? 0)</h2>
            <p>Awaiting confirmation</p>
        </div>

        <div class="card stat-card" style="cursor: pointer;" onclick="location.href='/AdminOrders?status=Completed'">
            <div class="card-icon"><i class="far fa-check-circle"></i></div>
            <h3>Completed Orders</h3>
            <h2>@(ViewData["CompletedOrdersCount"] ?? 0)</h2>
            <p>Successfully finished</p>
        </div>

        <div class="card stat-card">
            <div class="card-icon"><i class="far fa-calendar-alt"></i></div>
            <h3>This Week</h3>
            <h2>6</h2>
            <p>New bookings</p>
        </div>
    </div>

    <!-- 🌟 Top Services (Hardcoded UI elements, but cleaned up markup) -->
    <div class="section-box">
        <div class="section-header">
            <h2><i class="fas fa-star"></i> Top Services</h2>
        </div>

        <div class="service-item">
            <div class="service-info">
                <div class="rank-badge">#1</div>
                <div class="service-details">
                    <h4>Custom Nail Art Design</h4>
                    <p>2 bookings</p>
                </div>
            </div>
            <div class="service-price">
                <h4>₱1,020.00</h4>
                <p>Total revenue</p>
            </div>
        </div>

        <div class="service-item">
            <div class="service-info">
                <div class="rank-badge">#2</div>
                <div class="service-details">
                    <h4>Gel Manicure</h4>
                    <p>8 bookings</p>
                </div>
            </div>
            <div class="service-price">
                <h4>₱900.00</h4>
                <p>Total revenue</p>
            </div>
        </div>

        <div class="service-item">
            <div class="service-info">
                <div class="rank-badge">#3</div>
                <div class="service-details">
                    <h4>Full Set with Tips</h4>
                    <p>5 bookings</p>
                </div>
            </div>
            <div class="service-price">
                <h4>₱975.00</h4>
                <p>Total revenue</p>
            </div>
        </div>

        <div class="service-item">
            <div class="service-info">
                <div class="rank-badge">#4</div>
                <div class="service-details">
                    <h4>Luxury Spa Package</h4>
                    <p>8 bookings</p>
                </div>
            </div>
            <div class="service-price">
                <h4>₱960.00</h4>
                <p>Total revenue</p>
            </div>
        </div>
    </div>

    <!-- 🌟 Recent Orders Dashboard List View Block -->
    <div class="section-box">
        <div class="section-header">
            <h2><i class="fas fa-user-friends"></i> Recent Orders</h2>
            <span class="badge-total">@(ViewData["TotalOrdersCount"] ?? 0) total</span>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Order #</th>
                        <th>Customer</th>
                        <th>Delivery Method</th>
                        <th>Payment Method</th>
                        <th>Contact Number</th>
                        <th>Type</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Note: Once you want to populate this table block seamlessly, you can
                         pass a list from the controller and use: @* @foreach (var order in Model) *@ -->
                    <tr>
                        <td>D-1</td>
                        <td class="customer-info">Juan Dela Cruz<p>User Contact Details</p></td>
                        <td>Standard Delivery</td>
                        <td>GCash</td>
                        <td>09123456789</td>
                        <td><span class="badge">💅 Press-On</span></td>
                        <td>2026-06-16</td>
                        <td><span class="status status-pending"><i class="far fa-clock"></i> Pending</span></td>
                        <td>
                            <button type="button" class="btn-action" onclick="location.href='@Url.Action("Index", "AdminOrders", new { status = "Pending" })'">
                                <i class="fas fa-pencil-alt"></i>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>