@{
    ViewData["Title"] = "Home - Klaw By Krys";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Shadows+Into+Light+Two&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="stylesheet" href="~/css/home-page.css" />
    <style>
        .featured-subheading {
            font-family: var(--primary-font);
            font-size: 2.2rem;
            color: var(--text-dark-brown);
            text-align: center;
            margin: 32px 0 16px;
            font-weight: normal;
        }
        .featured-card {
            position: relative;
            aspect-ratio: 1;
            border-radius: 16px;
            overflow: hidden;
            background-size: cover;
            background-position: center;
            border: 6px solid #fde6ea;
            box-shadow: 0 8px 18px rgba(0,0,0,.06);
            display: flex;
            align-items: flex-end;
            text-decoration: none;
            transition: transform 0.3s ease, border-color 0.3s, box-shadow 0.3s;
        }
        .featured-card:hover {
            transform: translateY(-5px);
            border-color: #f0b8cc;
            box-shadow: 0 12px 24px rgba(240, 184, 204, 0.35);
        }
        .card-overlay {
            width: 100%;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(4px);
            padding: 12px 8px;
            text-align: center;
            border-top: 1px solid #fde6ea;
            transition: background 0.3s ease;
            box-sizing: border-box;
        }
        .featured-card:hover .card-overlay {
            background: rgba(255, 255, 255, 0.95);
        }
        .card-title {
            font-family: var(--secondary-font);
            font-weight: 600;
            font-size: 0.95rem;
            color: var(--text-dark-brown);
            display: block;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin: 0;
        }
    </style>
}

<div class="home-wrapper">

    <section class="hero-section">
        <div class="hero-content">
            <div class="section-icons">
                <i class="fas fa-sparkles"></i>
                <i class="fas fa-heart"></i>
                <i class="fas fa-sparkles"></i>
            </div>
            <h1 class="hero-title">Welcome to Klaw By Krys</h1>
            <h2 class="hero-subtitle">Quality & Creative Nail Sets</h2>
            <p class="hero-text">Your boutique nail studio offering creative media and amazing nail art. Each set is designed with love, care, and attention to detail.</p>
            <a href="/Appointment" class="btn-main">Book Appointment</a>
        </div>
    </section>

    <section class="home-section featured-section">
        <div class="section-header">
            <h2 class="section-title"><i class="fas fa-sparkles title-icon-pink"></i> Featured Works <i class="fas fa-sparkles title-icon-pink"></i></h2>
            <p class="section-subtitle">Discover our most popular creations</p>
        </div>

        <h3 class="featured-subheading">Original Sets</h3>
        <div class="featured-grid">
            @foreach(var p in ViewData["FeaturedOriginals"] as IEnumerable<KlawQ.Models.Products> ?? Enumerable.Empty<KlawQ.Models.Products>())
            {
                var img = p.Product_Image;
                if (string.IsNullOrWhiteSpace(img)) img = Url.Content("~/images/placeholder.png");
                else if (img.StartsWith("~")) img = Url.Content(img);
                else if (!img.StartsWith("/")) img = Url.Content("~/" + img.TrimStart('/'));
                else img = Url.Content(img);

                <a href="/Gallery/Details/@p.ProductID" class="featured-card" style="background-image: url('@img');">
                    <div class="card-overlay">
                        <span class="card-title">@p.Product_Name</span>
                    </div>
                </a>
            }
        </div>

        <h3 class="featured-subheading">Press-On Sets</h3>
        <div class="featured-grid">
            @foreach(var p in ViewData["FeaturedPressOns"] as IEnumerable<KlawQ.Models.Products> ?? Enumerable.Empty<KlawQ.Models.Products>())
            {
                var img = p.Product_Image;
                if (string.IsNullOrWhiteSpace(img)) img = Url.Content("~/images/placeholder.png");
                else if (img.StartsWith("~")) img = Url.Content(img);
                else if (!img.StartsWith("/")) img = Url.Content("~/" + img.TrimStart('/'));
                else img = Url.Content(img);

                <a href="/Gallery/Details/@p.ProductID" class="featured-card" style="background-image: url('@img');">
                    <div class="card-overlay">
                        <span class="card-title">@p.Product_Name</span>
                    </div>
                </a>
            }
        </div>
    </section>

    @if (User.Identity?.IsAuthenticated == true)
    {
        var orderHistory = ViewData["OrderHistory"] as IEnumerable<KlawQ.Models.OrderItem> ?? Enumerable.Empty<KlawQ.Models.OrderItem>();
        <section class="home-section bookmarks-section">
            <div class="section-header">
                <h2 class="section-title"><i class="fas fa-box title-icon-green"></i> My Order History <i class="fas fa-box title-icon-green"></i></h2>
                <p class="section-subtitle">View your ordered press-ons here.</p>
            </div>

            <div class="bookmarks-board">
                @if (orderHistory.Any())
                {
                    @if (orderHistory.Count() > 3)
                    {
                        <div class="board-actions">
                            <button id="btnToggleHistory" class="btn-add-bookmark">Show More</button>
                        </div>
                    }

                    <div class="table-responsive">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Picture</th>
                                    <th>Title</th>
                                    <th>Quantity</th>
                                    <th>Price</th>
                                    <th style="text-align: center;">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="historyTableBody">
                                @{
                                    int index = 0;
                                }
                                @foreach (var item in orderHistory)
                                {
                                    var img = item.Product?.Product_Image;
                                    if (string.IsNullOrWhiteSpace(img)) img = Url.Content("~/images/placeholder.png");
                                    else if (img.StartsWith("~")) img = Url.Content(img);
                                    else if (!img.StartsWith("/")) img = Url.Content("~/" + img.TrimStart('/'));
                                    else img = Url.Content(img);

                                    var rowClass = index >= 3 ? "history-row-hidden" : "";
                                    var rowStyle = index >= 3 ? "display: none;" : "";

                                    <tr class="@rowClass" style="@rowStyle">
                                        <td style="width: 80px; vertical-align: middle;">
                                            <img src="@img" alt="@(item.Product?.Product_Name)" style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px; border: 1px solid var(--border-pink);" />
                                        </td>
                                        <td style="vertical-align: middle; font-weight: 500;">@(item.Product?.Product_Name ?? "Press-On Set")</td>
                                        <td style="vertical-align: middle;">@item.Quantity</td>
                                        <td style="vertical-align: middle;">₱@((item.Product?.Product_Price ?? 0).ToString("N2"))</td>
                                        <td style="vertical-align: middle; text-align: center;">
                                            <div class="action-buttons" style="justify-content: center;">
                                                <a href="/Order/OrderDetails/@item.OrderID" class="action-btn" style="text-decoration: none;" title="View Order Details">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                    index++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div style="text-align: center; padding: 2rem 0; color: var(--text-light-brown);">
                        <i class="fas fa-receipt" style="font-size: 3rem; margin-bottom: 1rem; color: var(--border-pink);"></i>
                        <p style="font-family: var(--secondary-font); font-size: 1.1rem; margin: 0;">You haven't ordered any press-ons yet.</p>
                    </div>
                }
            </div>
        </section>
    }

    <section class="home-section testimonials-section">
        <div class="section-header">
            <h2 class="section-title"><i class="fas fa-heart title-icon-pink"></i> Client Love <i class="fas fa-heart title-icon-pink"></i></h2>
            <p class="section-subtitle">What our wonderful clients say</p>
        </div>

        <div class="testimonials-grid">
            <div class="testimonial-card">
                <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                <p class="quote">"My nails have honestly never looked better! The attention to detail is insane, and the custom sizing fits my nail beds perfectly. I get so many compliments everywhere I go!"</p>
                <p class="author">— Sarah M.</p>
            </div>

            <div class="testimonial-card">
                <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                <p class="quote">"Such an amazing experience! Krys is so talented and the quality of the press-ons is top-tier. They lasted me a whole month. Absolutely love them!"</p>
                <p class="author">— Jessica R.</p>
            </div>

            <div class="testimonial-card">
                <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                <p class="quote">"I've tried so many nail techs, but this is by far the best retention I've ever had. She is so careful and her designs are incredible."</p>
                <p class="author">— Emma T.</p>
            </div>
        </div>
    </section>

    <section class="home-section faq-section">
        <div class="section-header">
            <h2 class="section-title"><i class="fas fa-star title-icon-green"></i> Frequently Asked Questions <i class="fas fa-star title-icon-green"></i></h2>
        </div>

        <div class="faq-container">

            <h3 class="faq-category">General Pricing</h3>
            <details class="faq-item">
                <summary>What's your rate?</summary>
                <div class="faq-content">
                    <p>Price will depend on the design but here's a price range for your reference:</p>
                    <p>
                        <strong>Press ons:</strong><br>
                        Basic color (No design) - ₱120<br>
                        Basic (Minimal design) - ₱150-250<br>
                        Creative designs - ₱200-400
                    </p>

                    <p>
                        <strong>Soft gel:</strong><br>
                        Solid color / Plain - ₱380<br>
                        Basic (Minimal design) - ₱400-550<br>
                        Creative designs - ₱550-900
                    </p>
                    <p><em>Please do ask first because pricing is based on the design PER NAIL.</em></p>
                </div>
            </details>

            <h3 class="faq-category">Soft Gel FAQ</h3>
            <details class="faq-item">
                <summary>How long do they usually last?</summary>
                <div class="faq-content"><p>Soft gel extensions last 3-7 weeks! It’s best to have them removed or changed after 3-4 weeks (1 month) to avoid damaging your natural nails.</p></div>
            </details>
            <details class="faq-item">
                <summary>Do you accept walk-ins?</summary>
                <div class="faq-content"><p>Strictly by appointments only. This way I can allocate enough time to provide the best experience and quality you deserve.</p></div>
            </details>
            <details class="faq-item">
                <summary>How long will the appointment take?</summary>
                <div class="faq-content"><p>It usually takes 2-4 hours, depending on your nail design.</p></div>
            </details>
            <details class="faq-item">
                <summary>Is there a warranty if ever one of my nail comes off?</summary>
                <div class="faq-content">
                    <p>
                        Yes !!<br>
                        2 days warranty for gel manicure<br>
                        5 days warranty for soft gel
                    </p>
                    <p>Please note that cases of forced removal are not covered by the warranty, as I can tell whether the nail was forcibly removed or not. You can have a back job (repair) within the warranty. Changing the design is not allowed!</p>
                </div>
            </details>
            <details class="faq-item">
                <summary>Can I get a refund?</summary>
                <div class="faq-content"><p>Down payment is non-refundable. If you paid in full and decide to cancel your appointment, the remaining balance can be refunded, except for the DP.</p></div>
            </details>
            <details class="faq-item">
                <summary>Can I reschedule my appointment?</summary>
                <div class="faq-content"><p>Yes. You may reschedule your appointment ONCE only! Failure to show up on the rescheduled appointment will result in automatic cancellation, as the reserved time slot could have been given to another client. Your downpayment will cover the NO-SHOW/CANCEL FEE.</p></div>
            </details>

            <h3 class="faq-category">Press Ons FAQ</h3>
            <details class="faq-item">
                <summary>What’s included in each set?</summary>
                <div class="faq-content">
                    <ul class="clean-list">
                        <li>10 pc nails</li>
                        <li>1 nail glue</li>
                        <li>Cuticle pusher</li>
                        <li>Mini nail file</li>
                        <li>Alcohol pad</li>
                        <li>Application & removal instructions</li>
                    </ul>
                </div>
            </details>
            <details class="faq-item">
                <summary>How long do the nails last?</summary>
                <div class="faq-content">
                    <p>With proper care: 3-7 days. They are reusable! You can remove and reuse them multiple times with care ^^</p>
                </div>
            </details>
            <details class="faq-item">
                <summary>Where do you ship and how much?</summary>
                <div class="faq-content">
                    <p>We ship nationwide via J&T shipping!</p>
                    <ul class="clean-list">
                        <li>Luzon - ₱75-85</li>
                        <li>Metro Manila - ₱95</li>
                        <li>Visayas - ₱100</li>
                        <li>Mindanao - ₱110</li>
                        <li>Island - ₱115</li>
                    </ul>
                    <p><em>J&T SF may still vary. Feel free to ask me by sending your City/Province so I could check on the app itself ^^</em></p>
                </div>
            </details>
            <details class="faq-item">
                <summary>Do you accept rush order?</summary>
                <div class="faq-content"><p>Yes, but it still depends on my availability. Please message me to check if I can accommodate a rush order before placing one.</p></div>
            </details>
            <details class="faq-item">
                <summary>Can I wear them in water or while doing chores?</summary>
                <div class="faq-content"><p>They're water-resistant, not waterproof. Please avoid soaking them or doing heavy chores to make them last longer.</p></div>
            </details>

        </div>
    </section>

</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const btnToggle = document.getElementById("btnToggleHistory");
            if (btnToggle) {
                const hiddenRows = document.querySelectorAll(".history-row-hidden");
                let isExpanded = false;

                btnToggle.addEventListener("click", function () {
                    isExpanded = !isExpanded;
                    hiddenRows.forEach(row => {
                        row.style.display = isExpanded ? "table-row" : "none";
                    });
                    btnToggle.textContent = isExpanded ? "Show Less" : "Show More";
                });
            }
        });
    </script>
}