@{
ViewData["Title"] = "Home - Klaw By Krys";
}

@section Styles {
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Shadows+Into+Light+Two&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<link rel="stylesheet" href="~/css/home-page.css" asp-append-version="true" />
<style>
    .featured-subheading {
    font-family: var(--primary-font);
    font-size: 2.2rem;
    color: var(--text-dark-brown);
    text-align: center;
    margin: 32px 0 16px;
    font-weight: normal;
}
.featured-card {
position: relative;
aspect-ratio: 1;
border-radius: 16px;
overflow: hidden;
background-size: cover;
background-position: center;
border: 6px solid #fde6ea;
box-shadow: 0 8px 18px rgba(0,0,0,.06);
display: flex;
align-items: flex-end;
text-decoration: none;
transition: transform 0.3s ease, border-color 0.3s, box-shadow 0.3s;
}
.featured-card:hover {
transform: translateY(-5px);
border-color: #f0b8cc;
box-shadow: 0 12px 24px rgba(240, 184, 204, 0.35);
}
.card-overlay {
width: 100%;
background: rgba(255, 255, 255, 0.85);
backdrop-filter: blur(4px);
padding: 12px 8px;
text-align: center;
border-top: 1px solid #fde6ea;
transition: background 0.3s ease;
box-sizing: border-box;
}
.featured-card:hover .card-overlay {
background: rgba(255, 255, 255, 0.95);
}
.card-title {
font-family: var(--secondary-font);
font-weight: 600;
font-size: 0.95rem;
color: var(--text-dark-brown);
display: block;
white-space: nowrap;
overflow: hidden;
text-overflow: ellipsis;
margin: 0;
}
</style>
}

<div class="home-wrapper">

    <section class="hero-section">
        <div class="hero-content">
            <div class="section-icons">
                <i class="fas fa-sparkles"></i>
                <i class="fas fa-heart"></i>
                <i class="fas fa-sparkles"></i>
            </div>
            <h1 class="hero-title">Welcome to Klaw By Krys</h1>
            <h2 class="hero-subtitle">Quality & Creative Nail Sets</h2>
            <p class="hero-text">Your boutique nail studio offering creative media and amazing nail art. Each set is designed with love, care, and attention to detail.</p>
            <a href="/Appointment" class="btn-main">Book Appointment</a>
        </div>
    </section>

    <section class="home-section featured-section">
        <div class="section-header">
            <h2 class="section-title"><i class="fas fa-sparkles title-icon-pink"></i> Featured Works <i class="fas fa-sparkles title-icon-pink"></i></h2>
            <p class="section-subtitle">Discover our most popular creations</p>
        </div>

        <h3 class="featured-subheading">Original Sets</h3>
        <div class="featured-grid">
            @foreach (var p in ViewData["FeaturedOriginals"] as IEnumerable<KlawQ.Models.Products> ?? Enumerable.Empty<KlawQ.Models.Products>())
            {
                var img = p.Product_Image;
                if (string.IsNullOrWhiteSpace(img)) img = Url.Content("~/images/placeholder.png");
                else if (img.StartsWith("~")) img = Url.Content(img);
                else if (!img.StartsWith("/")) img = Url.Content("~/" + img.TrimStart('/'));
                else img = Url.Content(img);

                <a href="/Gallery/Details/@p.ProductID" class="featured-card" style="background-image: url('@img');">
                    <div class="card-overlay">
                        <span class="card-title">@p.Product_Name</span>
                    </div>
                </a>
            }
        </div>

        <h3 class="featured-subheading">Press-On Sets</h3>
        <div class="featured-grid">
            @foreach (var p in ViewData["FeaturedPressOns"] as IEnumerable<KlawQ.Models.Products> ?? Enumerable.Empty<KlawQ.Models.Products>())
            {
                var img = p.Product_Image;
                if (string.IsNullOrWhiteSpace(img)) img = Url.Content("~/images/placeholder.png");
                else if (img.StartsWith("~")) img = Url.Content(img);
                else if (!img.StartsWith("/")) img = Url.Content("~/" + img.TrimStart('/'));
                else img = Url.Content(img);

                <a href="/Gallery/Details/@p.ProductID" class="featured-card" style="background-image: url('@img');">
                    <div class="card-overlay">
                        <span class="card-title">@p.Product_Name</span>
                    </div>
                </a>
            }
        </div>
    </section>

    <!-- Meet the Artist (Backstory) Section -->
    <section class="home-section about-section">
        <div class="about-image-wrap">
            <img src="~/images/gallery/meet_the_creator.jpg" alt="Meet the Creator - Klaw By Krys" class="about-image" />
        </div>
        <div class="about-content">
            <div style="color: var(--accent-green); font-size: 1.1rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase;">Meet the Creator</div>
            <h2 class="about-quote">"Nails are small canvases of joy, and each set is a miniature work of art built just for you."</h2>
            <p style="line-height: 1.7; font-size: 1.05rem; margin: 0.5rem 0 0 0;">
                Hi! I’m Kryssa, a passionate nail tech who started my nail journey at 18. What began as a creative hobby quickly grew into something I truly love, and ever since, I’ve been dedicated to perfecting my craft and bringing my clients’ nail visions to life. I believe that every set of nails should not only look beautiful but also make you feel confident and express your unique style.
            </p>
            <p style="line-height: 1.7; font-size: 1.05rem; margin: 12px 0 0 0;">
                One thing I’m known for is being a “copy-paste” nail tech. A title lovingly given to me by many of my clients. Whether you have a specific inspiration photo or a Pinterest board full of ideas, I’ll do my best to recreate your dream set as accurately as possible. From simple to intricate nail art, my goal is always the same: to create nails you can’t stop looking at.
            </p>
            <div style="font-family: var(--primary-font); font-size: 1.8rem; color: var(--text-dark-brown); margin-top: 0.5rem;">— Kryssa, Founder & Nail Artist</div>
        </div>
    </section>

    <!-- Why Choose Us Features Grid -->
    <section class="home-section features-section">
        <div class="section-header">
            <h2 class="section-title"><i class="fas fa-magic title-icon-pink"></i> The Klaw Difference <i class="fas fa-magic title-icon-pink"></i></h2>
            <p class="section-subtitle">What makes our press-on sets special</p>
        </div>

        <div class="features-grid">
            <div class="feature-card">
                <i class="fas fa-paint-brush feature-icon"></i>
                <h4 class="feature-title">Hand-Painted</h4>
                <p class="feature-desc">Meticulously painted using professional, salon-grade gel polishes for ultimate vibrancy.</p>
            </div>

            <div class="feature-card">
                <i class="fas fa-rotate-left feature-icon"></i>
                <h4 class="feature-title">Reusable</h4>
                <p class="feature-desc">Apply and remove with care to enjoy your gorgeous sets multiple times.</p>
            </div>

            <div class="feature-card">
                <i class="fas fa-ruler-horizontal feature-icon"></i>
                <h4 class="feature-title">Custom Sized</h4>
                <p class="feature-desc">Made to order using your precise nail measurements for a perfect, comfortable fit.</p>
            </div>

            <div class="feature-card">
                <i class="fas fa-shipping-fast feature-icon"></i>
                <h4 class="feature-title">Convenient</h4>
                <p class="feature-desc">Get premium boutique nails delivered to your door. Skip the long salon chair visits.</p>
            </div>
        </div>
    </section>

    <section class="home-section testimonials-section">
        <div class="section-header">
            <h2 class="section-title"><i class="fas fa-heart title-icon-pink"></i> Client Love <i class="fas fa-heart title-icon-pink"></i></h2>
            <p class="section-subtitle">What our wonderful clients say</p>
        </div>

        <div class="testimonials-grid">
            <div class="testimonial-card">
                <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                <p class="quote">"My nails have honestly never looked better! The attention to detail is insane, and the custom sizing fits my nail beds perfectly. I get so many compliments everywhere I go!"</p>
                <p class="author">— Sarah M.</p>
            </div>

            <div class="testimonial-card">
                <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                <p class="quote">"Such an amazing experience! Kryssa is so talented and the quality of the press-ons is top-tier. They lasted me a whole month. Absolutely love them!"</p>
                <p class="author">— Jessica R.</p>
            </div>

            <div class="testimonial-card">
                <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                <p class="quote">"I've tried so many nail techs, but this is by far the best retention I've ever had. She is so careful and her designs are incredible."</p>
                <p class="author">— Emma T.</p>
            </div>
        </div>
    </section>

</div>