@{
    ViewData["Title"] = "Home";
}

<style>
    :root{
        --bg-pink: #fff5f6;
        --panel-pink: #fdeef0;
        --accent-pink: #fde0e2;
        --brand-brown: #8b4b3b;
        --footer-brown: #6b4228;
        --cta-green: #88b04b;
        --light-green: #c5f08f;
    }
    
    /* Main container */
    .container { max-width:1200px; margin:0 auto; padding:0 20px; }
    
    /* Hero section */
    .hero { padding:60px 20px; text-align:center; }
    .hero h1 { font-size:48px; font-weight:300; color:var(--brand-brown); margin:20px 0; }
    .hero .subtitle { color:#999; font-size:16px; }
    .hero .description { color:#999; font-size:14px; max-width:600px; margin:10px auto 30px; }
    .btn-appointment { background:var(--cta-green); color:white; padding:12px 30px; border-radius:25px; text-decoration:none; display:inline-block; }
    
    /* Section divider */
    .divider { height:2px; background:var(--accent-pink); margin:40px 0; }
    
    /* Featured Works */
    .section { padding:60px 20px; }
    .section-title { text-align:center; font-size:32px; color:var(--brand-brown); margin:20px 0; }
    .section-desc { text-align:center; color:#999; font-size:14px; margin:10px 0 40px; }
    .gallery { display:grid; grid-template-columns:repeat(3, 1fr); gap:30px; margin:40px 0; }
    .gallery-item { background:var(--light-green); aspect-ratio:1; border-radius:12px; }
    
    /* Bookmarks section */
    .bookmarks-table { background:#fff; border-radius:12px; padding:20px; margin:30px 0; box-shadow:0 2px 8px rgba(0,0,0,.05); }
    .btn-add { background:var(--cta-green); color:white; padding:8px 16px; border-radius:20px; text-decoration:none; font-size:12px; display:inline-block; margin:20px 0; }
    table { width:100%; border-collapse:collapse; }
    th { text-align:left; padding:12px; color:var(--brand-brown); font-size:12px; border-bottom:1px solid #eee; }
    td { padding:12px; border-bottom:1px solid #eee; font-size:13px; }
    
    /* Client Love */
    .testimonials { display:grid; grid-template-columns:repeat(3, 1fr); gap:20px; margin:40px 0; }
    .testimonial { background:#fff; border:2px solid var(--accent-pink); border-radius:12px; padding:20px; }
    .stars { color:var(--cta-green); font-size:14px; }
    .testimonial p { font-size:13px; color:#666; margin:10px 0; }
    .author { font-weight:600; font-size:12px; color:var(--brand-brown); }
    
    /* FAQ */
    .faq { margin:40px 0; }

    .faq-item {
        background:#fff;
        border:1px solid #e8d5d8;
        border-radius:14px;
        margin:12px 0;
        overflow:hidden;
        box-shadow:0 2px 8px rgba(139,75,59,.06);
        transition: box-shadow .3s ease, transform .3s ease;
        opacity: 0;
        transform: translateY(20px);
    }
    .faq-item.faq-visible {
        opacity: 1;
        transform: translateY(0);
    }
    .faq-item:hover {
        box-shadow:0 6px 20px rgba(139,75,59,.13);
        transform: translateY(-2px);
    }
    .faq-item.active {
        border-color: var(--brand-brown);
        box-shadow:0 6px 20px rgba(139,75,59,.15);
    }

    .faq-question {
        padding: 18px 20px;
        cursor: pointer;
        background: var(--panel-pink);
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 600;
        font-size: 14px;
        color: var(--brand-brown);
        transition: background .25s ease;
        user-select: none;
    }
    .faq-question:hover { background: var(--accent-pink); }
    .faq-item.active .faq-question { background: var(--accent-pink); }

    .faq-arrow {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: var(--brand-brown);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        flex-shrink: 0;
        transition: transform .35s cubic-bezier(.4,0,.2,1), background .25s ease;
    }
    .faq-item.active .faq-arrow {
        transform: rotate(180deg);
        background: var(--cta-green);
    }

    .faq-answer {
        max-height: 0;
        overflow: hidden;
        transition: max-height .4s cubic-bezier(.4,0,.2,1), padding .3s ease;
        padding: 0 20px;
        font-size: 13px;
        color: #666;
        line-height: 1.7;
    }
    .faq-item.active .faq-answer {
        max-height: 200px;
        padding: 14px 20px 18px;
    }
    
    /* Footer */
    footer { background:var(--footer-brown); color:#fff; padding:30px; margin-top:60px; text-align:center; }
    .footer-content { max-width:1200px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr 1fr; gap:30px; text-align:left; margin-bottom:20px; }
    .footer-col { font-size:14px; }
    
    @@media(max-width:768px) {
        .gallery { grid-template-columns:1fr; }
        .testimonials { grid-template-columns:1fr; }
        .footer-content { grid-template-columns:1fr; }
    }
</style>

<div class="container">
    <div class="hero">
        <h1>Welcome to Klaw By Krys</h1>
        <p class="subtitle">Quality & Creative Nail Sets</p>
        <p class="description">Your boutique nail studio where creativity meets craftsmanship. Each set is designed with love, care, and attention to detail.</p>
        <a asp-controller="Appointment" asp-action="Index" class="btn-appointment">Book Appointment</a>
    </div>

    <div class="divider"></div>

    <div class="section">
        <h2 class="section-title">✨ Featured Works ✨</h2>
        <p class="section-desc">Discover our latest nail art creations</p>
        <div class="gallery">
            <div class="gallery-item"></div>
            <div class="gallery-item"></div>
            <div class="gallery-item"></div>
        </div>
    </div>

    <div class="divider"></div>

    <div class="section">
        <h2 class="section-title">🎀 My Design Bookmarks 🎀</h2>
        <p class="section-desc">Save all your design inspiration</p>
        <div class="bookmarks-table">
            <a href="#" class="btn-add">+ Add New Bookmark</a>
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>URL</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>#1</td>
                        <td>Floral Nail Art Inspiration</td>
                        <td>https://designs.com/floral</td>
                        <td>❤️ 🗑️</td>
                    </tr>
                    <tr>
                        <td>#2</td>
                        <td>Minimalist Nails</td>
                        <td>https://designs.com/minimal</td>
                        <td>❤️ 🗑️</td>
                    </tr>
                    <tr>
                        <td>#3</td>
                        <td>French Tip Variations</td>
                        <td>https://designs.com/french-tips</td>
                        <td>❤️ 🗑️</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="divider"></div>

    <div class="section">
        <h2 class="section-title">💕 Client Love 💕</h2>
        <div class="testimonials">
            <div class="testimonial">
                <div class="stars">★★★★★</div>
                <p>"Klaw By Krys created the most stunning nail designs! The attention to detail is incredible. Highly recommend for anyone looking for quality nail art!"</p>
                <div class="author">— Sarah M.</div>
            </div>
            <div class="testimonial">
                <div class="stars">★★★★★</div>
                <p>"Excellent work and great customer service. I've been to many nail salons, but this one stands out. The creativity and precision are unmatched!"</p>
                <div class="author">— Jessica L.</div>
            </div>
            <div class="testimonial">
                <div class="stars">★★★★★</div>
                <p>"Every time I visit, I leave with gorgeous nails and a smile. The team is professional and truly cares about making me feel special."</p>
                <div class="author">— Emma K.</div>
            </div>
        </div>
    </div>

    <div class="divider"></div>

    <div class="section">
        <h2 class="section-title">✨ Frequently Asked Questions ✨</h2>
        <div class="faq" id="faq-list">
            <div class="faq-item">
                <div class="faq-question" onclick="toggleFaq(this)">How long does a nail appointment take? <span class="faq-arrow">&#9660;</span></div>
                <div class="faq-answer">Most appointments take 45-60 minutes depending on the complexity of your design.</div>
            </div>
            <div class="faq-item">
                <div class="faq-question" onclick="toggleFaq(this)">How do I book an appointment? <span class="faq-arrow">&#9660;</span></div>
                <div class="faq-answer">You can book directly through our website or contact us via Instagram.</div>
            </div>
            <div class="faq-item">
                <div class="faq-question" onclick="toggleFaq(this)">What's your cancellation policy? <span class="faq-arrow">&#9660;</span></div>
                <div class="faq-answer">Cancellations must be made 24 hours in advance for a full refund.</div>
            </div>
            <div class="faq-item">
                <div class="faq-question" onclick="toggleFaq(this)">Do you offer nail art consultations? <span class="faq-arrow">&#9660;</span></div>
                <div class="faq-answer">Yes! We provide free consultations to discuss your nail design ideas.</div>
            </div>
            <div class="faq-item">
                <div class="faq-question" onclick="toggleFaq(this)">What products do you use? <span class="faq-arrow">&#9660;</span></div>
                <div class="faq-answer">We use only premium quality, eco-friendly nail products for the best results.</div>
            </div>
        </div>

        <script>
            function toggleFaq(questionEl) {
                const item = questionEl.parentElement;
                const isActive = item.classList.contains('active');
                // Close all open items
                document.querySelectorAll('.faq-item.active').forEach(i => i.classList.remove('active'));
                // Open clicked one if it was closed
                if (!isActive) item.classList.add('active');
            }

            // Scroll-triggered fade-in for FAQ items
            const faqObserver = new IntersectionObserver((entries) => {
                entries.forEach((entry, i) => {
                    if (entry.isIntersecting) {
                        setTimeout(() => entry.target.classList.add('faq-visible'), i * 100);
                        faqObserver.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.15 });

            document.querySelectorAll('.faq-item').forEach(item => faqObserver.observe(item));
        </script>
    </div>
</div>

<footer>
    <div class="footer-content">
        <div class="footer-col">
            <strong>Klaw By Krys</strong><br/>
            Your boutique nail studio for creative & quality nail sets
        </div>
        <div class="footer-col">
            📸 Follow on Instagram
        </div>
        <div class="footer-col">
            📍 Studio Location<br/>
            123 Creative Lane<br/>
            Studio City, SC 12345
        </div>
    </div>
    <div style="text-align:center; border-top:1px solid rgba(255,255,255,.2); padding-top:15px; font-size:13px;">
        Made with ♥ by Klaw By Krys © 2026
    </div>
</footer>