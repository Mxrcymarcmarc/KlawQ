@{
    ViewData["Title"] = "Home - Klaw By Krys";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Shadows+Into+Light+Two&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="stylesheet" href="~/css/home-page.css" />
    <style>
        .featured-subheading {
            font-family: var(--primary-font);
            font-size: 2.2rem;
            color: var(--text-dark-brown);
            text-align: center;
            margin: 32px 0 16px;
            font-weight: normal;
        }
        .featured-card {
            position: relative;
            aspect-ratio: 1;
            border-radius: 16px;
            overflow: hidden;
            background-size: cover;
            background-position: center;
            border: 6px solid #fde6ea;
            box-shadow: 0 8px 18px rgba(0,0,0,.06);
            display: flex;
            align-items: flex-end;
            text-decoration: none;
            transition: transform 0.3s ease, border-color 0.3s, box-shadow 0.3s;
        }
        .featured-card:hover {
            transform: translateY(-5px);
            border-color: #f0b8cc;
            box-shadow: 0 12px 24px rgba(240, 184, 204, 0.35);
        }
        .card-overlay {
            width: 100%;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(4px);
            padding: 12px 8px;
            text-align: center;
            border-top: 1px solid #fde6ea;
            transition: background 0.3s ease;
            box-sizing: border-box;
        }
        .featured-card:hover .card-overlay {
            background: rgba(255, 255, 255, 0.95);
        }
        .card-title {
            font-family: var(--secondary-font);
            font-weight: 600;
            font-size: 0.95rem;
            color: var(--text-dark-brown);
            display: block;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin: 0;
        }
    </style>
}

<div class="home-wrapper">

    <section class="hero-section">
        <div class="hero-content">
            <div class="section-icons">
                <i class="fas fa-sparkles"></i>
                <i class="fas fa-heart"></i>
                <i class="fas fa-sparkles"></i>
            </div>
            <h1 class="hero-title">Welcome to Klaw By Krys</h1>
            <h2 class="hero-subtitle">Quality & Creative Nail Sets</h2>
            <p class="hero-text">Your boutique nail studio offering creative media and amazing nail art. Each set is designed with love, care, and attention to detail.</p>
            <a href="/Appointment" class="btn-main">Book Appointment</a>
        </div>
    </section>

    <section class="home-section featured-section">
        <div class="section-header">
            <h2 class="section-title"><i class="fas fa-sparkles title-icon-pink"></i> Featured Works <i class="fas fa-sparkles title-icon-pink"></i></h2>
            <p class="section-subtitle">Discover our most popular creations</p>
        </div>

        <h3 class="featured-subheading">Original Sets</h3>
        <div class="featured-grid">
            @foreach(var p in ViewData["FeaturedOriginals"] as IEnumerable<KlawQ.Models.Products> ?? Enumerable.Empty<KlawQ.Models.Products>())
            {
                var img = p.Product_Image;
                if (string.IsNullOrWhiteSpace(img)) img = Url.Content("~/images/placeholder.png");
                else if (img.StartsWith("~")) img = Url.Content(img);
                else if (!img.StartsWith("/")) img = Url.Content("~/" + img.TrimStart('/'));
                else img = Url.Content(img);

                <a href="/Gallery/Details/@p.ProductID" class="featured-card" style="background-image: url('@img');">
                    <div class="card-overlay">
                        <span class="card-title">@p.Product_Name</span>
                    </div>
                </a>
            }
        </div>

        <h3 class="featured-subheading">Press-On Sets</h3>
        <div class="featured-grid">
            @foreach(var p in ViewData["FeaturedPressOns"] as IEnumerable<KlawQ.Models.Products> ?? Enumerable.Empty<KlawQ.Models.Products>())
            {
                var img = p.Product_Image;
                if (string.IsNullOrWhiteSpace(img)) img = Url.Content("~/images/placeholder.png");
                else if (img.StartsWith("~")) img = Url.Content(img);
                else if (!img.StartsWith("/")) img = Url.Content("~/" + img.TrimStart('/'));
                else img = Url.Content(img);

                <a href="/Gallery/Details/@p.ProductID" class="featured-card" style="background-image: url('@img');">
                    <div class="card-overlay">
                        <span class="card-title">@p.Product_Name</span>
                    </div>
                </a>
            }
        </div>
    </section>

    <section class="home-section testimonials-section">
        <div class="section-header">
            <h2 class="section-title"><i class="fas fa-heart title-icon-pink"></i> Client Love <i class="fas fa-heart title-icon-pink"></i></h2>
            <p class="section-subtitle">What our wonderful clients say</p>
        </div>

        <div class="testimonials-grid">
            <div class="testimonial-card">
                <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                <p class="quote">"My nails have honestly never looked better! The attention to detail is insane, and the custom sizing fits my nail beds perfectly. I get so many compliments everywhere I go!"</p>
                <p class="author">— Sarah M.</p>
            </div>

            <div class="testimonial-card">
                <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                <p class="quote">"Such an amazing experience! Krys is so talented and the quality of the press-ons is top-tier. They lasted me a whole month. Absolutely love them!"</p>
                <p class="author">— Jessica R.</p>
            </div>

            <div class="testimonial-card">
                <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                <p class="quote">"I've tried so many nail techs, but this is by far the best retention I've ever had. She is so careful and her designs are incredible."</p>
                <p class="author">— Emma T.</p>
            </div>
        </div>
    </section>

</div>