@{
    ViewData["Title"] = "FAQ - Klaw By Krys";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/home-page.css" />
    <style>
        .home-wrapper {
            min-height: 70vh;
        }
        .faq-container {
            width: 100%;
            max-width: 800px;
            margin: 0 auto;
        }
        .faq-item {
            width: 100% !important;
            box-sizing: border-box;
        }
    </style>
}

<div class="home-wrapper">
    <section class="home-section faq-section" style="margin-top: 0;">
        <div class="section-header">
            <h2 class="section-title"><i class="fas fa-star title-icon-green"></i> Frequently Asked Questions <i class="fas fa-star title-icon-green"></i></h2>
        </div>

        <div class="faq-container">

            <h3 class="faq-category">General Pricing</h3>
            <details class="faq-item">
                <summary>What's your rate?</summary>
                <div class="faq-content">
                    <p>Price will depend on the design but here's a price range for your reference:</p>
                    <p>
                        <strong>Press ons:</strong><br>
                        Basic color (No design) - ₱120<br>
                        Basic (Minimal design) - ₱150-250<br>
                        Creative designs - ₱200-400
                    </p>

                    <p>
                        <strong>Soft gel:</strong><br>
                        Solid color / Plain - ₱380<br>
                        Basic (Minimal design) - ₱400-550<br>
                        Creative designs - ₱550-900
                    </p>
                    <p><em>Please do ask first because pricing is based on the design PER NAIL.</em></p>
                </div>
            </details>

            <h3 class="faq-category">Soft Gel FAQ</h3>
            <details class="faq-item">
                <summary>How long do they usually last?</summary>
                <div class="faq-content"><p>Soft gel extensions last 3-7 weeks! It’s best to have them removed or changed after 3-4 weeks (1 month) to avoid damaging your natural nails.</p></div>
            </details>
            <details class="faq-item">
                <summary>Do you accept walk-ins?</summary>
                <div class="faq-content"><p>Strictly by appointments only. This way I can allocate enough time to provide the best experience and quality you deserve.</p></div>
            </details>
            <details class="faq-item">
                <summary>How long will the appointment take?</summary>
                <div class="faq-content"><p>It usually takes 2-4 hours, depending on your nail design.</p></div>
            </details>
            <details class="faq-item">
                <summary>Is there a warranty if ever one of my nail comes off?</summary>
                <div class="faq-content">
                    <p>
                        Yes !!<br>
                        2 days warranty for gel manicure<br>
                        5 days warranty for soft gel
                    </p>
                    <p>Please note that cases of forced removal are not covered by the warranty, as I can tell whether the nail was forcibly removed or not. You can have a back job (repair) within the warranty. Changing the design is not allowed!</p>
                </div>
            </details>
            <details class="faq-item">
                <summary>Can I get a refund?</summary>
                <div class="faq-content"><p>Down payment is non-refundable. If you paid in full and decide to cancel your appointment, the remaining balance can be refunded, except for the DP.</p></div>
            </details>
            <details class="faq-item">
                <summary>Can I reschedule my appointment?</summary>
                <div class="faq-content"><p>Yes. You may reschedule your appointment ONCE only! Failure to show up on the rescheduled appointment will result in automatic cancellation, as the reserved time slot could have been given to another client. Your downpayment will cover the NO-SHOW/CANCEL FEE.</p></div>
            </details>

            <h3 class="faq-category">Press Ons FAQ</h3>
            <details class="faq-item">
                <summary>What’s included in each set?</summary>
                <div class="faq-content">
                    <ul class="clean-list">
                        <li>10 pc nails</li>
                        <li>1 nail glue</li>
                        <li>Cuticle pusher</li>
                        <li>Mini nail file</li>
                        <li>Alcohol pad</li>
                        <li>Application & removal instructions</li>
                    </ul>
                </div>
            </details>
            <details class="faq-item">
                <summary>How long do the nails last?</summary>
                <div class="faq-content">
                    <p>With proper care: 3-7 days. They are reusable! You can remove and reuse them multiple times with care ^^</p>
                </div>
            </details>
            <details class="faq-item">
                <summary>Where do you ship and how much?</summary>
                <div class="faq-content">
                    <p>We ship nationwide via J&T shipping!</p>
                    <ul class="clean-list">
                        <li>Luzon - ₱75-85</li>
                        <li>Metro Manila - ₱95</li>
                        <li>Visayas - ₱100</li>
                        <li>Mindanao - ₱110</li>
                        <li>Island - ₱115</li>
                    </ul>
                    <p><em>J&T SF may still vary. Feel free to ask me by sending your City/Province so I could check on the app itself ^^</em></p>
                </div>
            </details>
            <details class="faq-item">
                <summary>Do you accept rush order?</summary>
                <div class="faq-content"><p>Yes, but it still depends on my availability. Please message me to check if I can accommodate a rush order before placing one.</p></div>
            </details>
            <details class="faq-item">
                <summary>Can I wear them in water or while doing chores?</summary>
                <div class="faq-content"><p>They're water-resistant, not waterproof. Please avoid soaking them or doing heavy chores to make them last longer.</p></div>
            </details>

        </div>
    </section>
</div>
