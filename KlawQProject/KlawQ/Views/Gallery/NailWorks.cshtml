@{
    ViewData["Title"] = "Nail Works";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Shadows+Into+Light+Two&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="stylesheet" href="~/css/nail-works.css" />
}

<div class="nail-works-wrapper">
    <div class="nail-works-container">

        <div class="page-header">
            <div class="header-icons">
                <i class="fas fa-sparkles"></i>
                <i class="fas fa-heart"></i>
                <i class="fas fa-sparkles"></i>
            </div>
            <h1 class="page-title">Nail Works</h1>
            <p class="page-subtitle">Explore our collection of stunning nail art across different styles</p>
        </div>

        <div class="category-tabs">
            <button class="tab-btn active">Press-On Sets</button>
            <button class="tab-btn">Original Sets</button>
        </div>

        <div class="gallery-grid">

            <a href="/Home/CustomOrder" class="gallery-card custom-request-card">
                <div class="custom-request-content">
                    <i class="far fa-images custom-icon"></i>
                    <h3>Custom Request</h3>
                    <p>Click here to design your own set!</p>
                </div>
            </a>

            <div class="gallery-card">
                <img src="~/images/press-on-1.jpg" alt="Press On Design" class="nail-img">
            </div>
            <div class="gallery-card">
                <img src="~/images/press-on-2.jpg" alt="Press On Design" class="nail-img">
            </div>
            <div class="gallery-card"><div class="empty-placeholder"></div></div>
            <div class="gallery-card"><div class="empty-placeholder"></div></div>
            <div class="gallery-card"><div class="empty-placeholder"></div></div>

        </div>

    </div>
</div>