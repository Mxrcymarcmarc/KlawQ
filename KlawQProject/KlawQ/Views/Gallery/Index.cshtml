@model IEnumerable<KlawQ.Models.Products>
@{
    ViewData["Title"] = "Nail Works";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Shadows+Into+Light+Two&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="stylesheet" href="~/css/nail-works.css" />

    <style>
    /* Merged gallery styles from Backend for consistent appearance */
    .gallery-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:20px}
    .gallery-card, .gallery-item{background:#fff;border-radius:16px;overflow:hidden;position:relative;border:6px solid transparent;box-shadow:0 8px 18px rgba(0,0,0,.06);display:flex;flex-direction:column}
    /* make all cards square and same size */
    .gallery-card, .gallery-card.image-card, .custom-request-card{aspect-ratio:1;min-height:260px;max-height:400px;width:100%}
    .gallery-card.image-card{border-color:#fde6ea}
    .gallery-card.image-card img{width:100%;height:100%;object-fit:cover;display:block}
    /* center custom request content */
    .gallery-card.custom-request-card{display:flex;flex-direction:column;justify-content:center;align-items:center;padding:0;border:2px dashed #d9a6b2}
    .custom-request-content{text-align:center;padding:20px}
    .btn-heart, .favorite-btn{width:44px;height:44px;border-radius:999px;border:3px solid #fde6ea;background:#fff;display:inline-flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;box-shadow:0 2px 6px rgba(0,0,0,.08);transition:transform 0.2s ease}
    .btn-heart:hover, .favorite-btn:hover{transform:scale(1.1)}
    /* Two-icon approach: hollow shown by default, solid hidden */
    .btn-heart .heart-hollow, .favorite-btn .heart-hollow{color:#e2557a;display:inline}
    .btn-heart .heart-filled, .favorite-btn .heart-filled{color:#e2557a;display:none}
    /* When favorited: flip visibility */
    .btn-heart.favorited .heart-hollow, .favorite-btn.favorited .heart-hollow{display:none}
    .btn-heart.favorited .heart-filled, .favorite-btn.favorited .heart-filled{display:inline}
    .fav-pop { animation: heartPop 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275); }

    @@media(max-width:900px){.gallery-grid{grid-template-columns:repeat(2,1fr)}}
    @@media(max-width:560px){.gallery-grid{grid-template-columns:1fr}}
    </style>
}

<div class="nail-works-wrapper">
    <div class="nail-works-container">

        <div class="page-header">
            <div class="header-icons">
                <i class="fas fa-sparkles"></i>
                <i class="fas fa-heart"></i>
                <i class="fas fa-sparkles"></i>
            </div>
            <h1 class="page-title">Nail Works</h1>
            <p class="page-subtitle">Explore our collection of stunning nail art across different styles</p>
        </div>

        <div class="category-tabs">
            <button class="tab-btn active" data-filter="presson">Press-On Sets</button>
            <button class="tab-btn" data-filter="original">Original Sets</button>
        </div>

        <div class="gallery-grid">

            <a href="/Order/CheckoutCustom" class="gallery-card custom-request-card" data-type="presson">
                <div class="custom-request-content">
                    <i class="far fa-images custom-icon"></i>
                    <h3>Custom Request</h3>
                    <p>Click here to design your own set!</p>
                </div>
            </a>

            @{
                var favIds = ViewData["FavoritedIds"] as List<int> ?? new List<int>();
            }

            @foreach(var p in Model ?? Enumerable.Empty<KlawQ.Models.Products>()){
                var imgPath = p.Product_Image;
                if (string.IsNullOrWhiteSpace(imgPath)) imgPath = Url.Content("~/images/placeholder.png");
                else if (imgPath.StartsWith("~")) imgPath = Url.Content(imgPath);
                else if (!imgPath.StartsWith("/")) imgPath = Url.Content("~/" + imgPath.TrimStart('/'));
                else imgPath = Url.Content(imgPath);

                var isPressOn = (p.Product_Type ?? "").ToLower() == "presson";
                var dataType = isPressOn ? "presson" : "original";
                var detailsLink = "/Gallery/Details/" + p.ProductID;
            <div class="gallery-card image-card" data-type="@dataType">
                <button class="favorite-btn btn-heart @(favIds.Contains(p.ProductID) ? "favorited" : "")" data-id="@p.ProductID" aria-label="Favorite this set">
                    <i class="fa-regular fa-heart heart-hollow"></i>
                    <i class="fa-solid fa-heart heart-filled"></i>
                </button>
                <a class="card-link" href="@detailsLink" style="display:block">
                    @{
                        // Robustly obtain a title for the alt attribute in case the model property name differs
                        var titleObj = p.GetType().GetProperty("Product_Title")?.GetValue(p)
                                       ?? p.GetType().GetProperty("ProductTitle")?.GetValue(p)
                                       ?? p.GetType().GetProperty("Title")?.GetValue(p)
                                       ?? p.GetType().GetProperty("Name")?.GetValue(p)
                                       ?? (object)"";
                        var title = titleObj?.ToString() ?? "";
                    }
                    <img src="@imgPath" alt="@title" class="nail-img" />
                </a>
            </div>
            }

        </div>

    </div>
</div>

@* hidden antiforgery token for AJAX *@
<form style="display:none">@Html.AntiForgeryToken()</form>

@section Scripts {
    <script>
    // Category filter (adapted from Backend)
    document.querySelectorAll('.tab-btn').forEach(btn => btn.addEventListener('click', (e)=>{
        document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.getAttribute('data-filter');
        document.querySelectorAll('.gallery-card[data-type], .gallery-item[data-type]').forEach(item=>{
            if(filter==='all') item.style.display='';
            else {
                const types = (item.getAttribute('data-type')||'').split(/\s+/);
                item.style.display = types.includes(filter) ? '' : 'none';
            }
        });
    }));

    // apply default filter (presson)
    ;(function(){
        const el = document.querySelector('.tab-btn.active');
        if(el) el.click();
    })();

    // Favorite toggling is handled in ~/js/nail-works-favs.js to ensure server sync and single handler
    </script>
    <script src="~/js/nail-works.js"></script>
    <script src="~/js/nail-works-favs.js"></script>
}
