<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Klaw By Krys</title>
    <link rel="icon" type="image/png" href="~/images/gallery/logoklawqicon.png" />
    <link rel="stylesheet" href="/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Shadows+Into+Light+Two&family=Indie+Flower&family=Caveat:wght@400;700&family=Kalam:wght@300;400&display=swap">
    <link href="https://fonts.googleapis.com/css2?family=Shadows+Into+Light+Two&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    @RenderSection("Styles", required: false)
</head>
<body>
    @{
    var navbarMode = ViewData["NavbarMode"]?.ToString() ?? "full";
    }

    <nav class="sticky-nav">
        <div class="nav-container">
            <a class="nav-brand" asp-controller="Home" asp-action="Index">
                <img src="~/images/gallery/logoklawqicon.png" alt="Klaw By Krys Logo" style="height: 28px; width: auto; vertical-align: middle; margin-right: 6px;" />
                Klaw By Krys
            </a>
            @if (navbarMode == "full")
            {
                var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";
                <ul class="nav-links">
                    <li><a class="@(currentController == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a class="@(currentController == "Gallery" || currentController == "GalleryDetails" ? "active" : "")" asp-controller="Gallery" asp-action="Index">Gallery</a></li>
                    <li><a class="@(currentController == "Favorites" ? "active" : "")" asp-controller="Favorites" asp-action="Index">Favorites</a></li>
                    <li><a class="@(currentController == "Appointment" ? "active" : "")" asp-controller="Appointment" asp-action="Index">Appointment</a></li>
                </ul>

                <div class="cart-button">
                    <a href="/Cart" title="Cart">
                        🛒<span id="cartCount" class="cart-count">0</span>
                    </a>
                </div>
            }
            else if (navbarMode == "admin")
            {
                <ul class="nav-links">
                    <li>
                        <a href="/Account/Logout"
                           onclick="event.preventDefault(); document.getElementById('logoutForm').submit();">
                            Logout
                        </a>
                    </li>
                </ul>
            }
            else if (navbarMode == "none")
            {
                <!-- NO NAVBAR (Login/Register/Verification pages) -->
            }
        </div>
    </nav>

    <main role="main" class="main-content">
        @RenderBody()
    </main>
    <form id="logoutForm" action="/Account/Logout" method="post" style="display:none;">@Html.AntiForgeryToken()</form>
    <form id="logoutForm" action="/Account/Logout" method="post" style="display:none;">@Html.AntiForgeryToken()</form>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <footer class="site-footer">
        <div class="footer-inner">
            <div>
                <strong>Klaw By Krys</strong><br />
                Your boutique nail studio for creative & quality nail sets.<br />
            </div>

            <div class="footer-center">
                <a class="footer-btn" href="#">Follow on Instagram</a>
            </div>

            <div class="footer-right">
                <b>Studio Location</b><br />
                123 Creative Lane<br />
                Studio City, SC 12345
            </div>
        </div>

        <div class="footer-bottom">
            Made with ♥ by Klaw By Krys © 2026
        </div>
    </footer>

    <script src="~/js/cart-popup.js"></script>
    @RenderSection("Scripts", required: false)
  
</body>
</html>
