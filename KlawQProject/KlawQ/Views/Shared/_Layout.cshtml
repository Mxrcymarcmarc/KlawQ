<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Klaw By Krys</title>
    <link rel="icon" type="image/png" href="~/images/gallery/IconLogoKlawQ3.png" />
    <link rel="stylesheet" href="/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Shadows+Into+Light+Two&family=Indie+Flower&family=Caveat:wght@400;700&family=Kalam:wght@300;400&display=swap">
    <link href="https://fonts.googleapis.com/css2?family=Shadows+Into+Light+Two&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    @RenderSection("Styles", required: false)
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
        var navbarMode = ViewData["NavbarMode"]?.ToString();
        if (string.IsNullOrEmpty(navbarMode))
        {
            if (currentController.StartsWith("Admin", StringComparison.OrdinalIgnoreCase))
            {
                navbarMode = "admin";
            }
            else
            {
                navbarMode = "full";
            }
        }
    }

    <nav class="sticky-nav">
        <div class="nav-container">
            <div class="nav-brand-group">
                @if (navbarMode == "full" && User.Identity?.IsAuthenticated == true)
                {
                    <button id="navGearBtn" class="nav-gear-btn" title="Settings Menu">
                        <i class="fas fa-cog"></i>
                    </button>
                }
                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (navbarMode == "admin")
                    {
                        <a class="nav-brand" href="/admin">
                            <img src="~/images/gallery/IconLogoKlawQ3.png" alt="Klaw By Krys Logo" style="height: 28px; width: auto; vertical-align: middle; margin-right: 6px;" />
                            Klaw By Krys
                        </a>
                    }
                    else
                    {
                        <a class="nav-brand" asp-controller="Home" asp-action="Index">
                            <img src="~/images/gallery/IconLogoKlawQ3.png" alt="Klaw By Krys Logo" style="height: 28px; width: auto; vertical-align: middle; margin-right: 6px;" />
                            Klaw By Krys
                        </a>
                    }
                }
                else
                {
                    <span class="nav-brand" style="cursor: default;">
                        <img src="~/images/gallery/IconLogoKlawQ3.png" alt="Klaw By Krys Logo" style="height: 28px; width: auto; vertical-align: middle; margin-right: 6px;" />
                        Klaw By Krys
                    </span>
                }
            </div>
            @if (navbarMode == "full")
            {
                <ul class="nav-links">
                    <li><a class="@(currentController == "Home" && currentAction == "Index" ? "active" : "")" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a class="@(currentController == "Gallery" || currentController == "GalleryDetails" ? "active" : "")" asp-controller="Gallery" asp-action="Index">Gallery</a></li>
                    <li><a class="@(currentController == "Favorites" ? "active" : "")" asp-controller="Favorites" asp-action="Index">Favorites</a></li>
                    <li><a class="@(currentController == "Appointment" ? "active" : "")" asp-controller="Appointment" asp-action="Index">Appointment</a></li>
                </ul>

                <div class="cart-button">
                    <a href="/Cart" title="Cart">
                        🛒<span id="cartCount" class="cart-count">0</span>
                    </a>
                </div>
            }
            else if (navbarMode == "admin")
            {
                <ul class="nav-links">
                    <li>
                        <a href="#" onclick="triggerLogoutConfirmation(event)">
                            Logout
                        </a>
                    </li>
                </ul>
            }
            else if (navbarMode == "none")
            {
                <!-- NO NAVBAR -->
            }
        </div>
    </nav>

    <main role="main" class="main-content">
        @RenderBody()
    </main>
    <form id="logoutForm" action="/Account/Logout" method="post" style="display:none;">@Html.AntiForgeryToken()</form>

    @if (navbarMode == "full" && User.Identity?.IsAuthenticated == true)
    {
        <div id="sideSettingsDrawer" class="settings-drawer">
            <button id="closeDrawerBtn" class="close-drawer-btn" title="Close Menu">&times;</button>
            <div class="drawer-content">
                <ul class="drawer-menu drawer-menu-top">
                    <li>
                        <a href="/Account/Profile" class="drawer-item">
                            <i class="fa-solid fa-circle-user menu-icon"></i>
                            <span class="menu-text">View Profile</span>
                        </a>
                    </li>
                    <li>
                        <a href="/Home/OrderHistory" class="drawer-item">
                            <i class="fa-solid fa-clock-rotate-left menu-icon"></i>
                            <span class="menu-text">View Order History</span>
                        </a>
                    </li>
                    <li>
                        <a href="/Home/AppointmentHistory" class="drawer-item">
                            <i class="fa-solid fa-calendar-days menu-icon"></i>
                            <span class="menu-text">View Appointment History</span>
                        </a>
                    </li>
                    <li>
                        <a href="/Home/FAQ" class="drawer-item">
                            <i class="fa-solid fa-circle-info menu-icon"></i>
                            <span class="menu-text">View FAQ</span>
                        </a>
                    </li>
                </ul>
                <ul class="drawer-menu drawer-menu-bottom">
                    <li>
                        <a href="#" class="drawer-item" onclick="triggerLogoutConfirmation(event)">
                            <i class="fa-solid fa-right-from-bracket menu-icon"></i>
                            <span class="menu-text">Logout</span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
        <div id="drawerOverlay" class="drawer-overlay"></div>

        <script>
                document.addEventListener("DOMContentLoaded", function () {
                    const gearBtn = document.getElementById("navGearBtn");
                    const closeBtn = document.getElementById("closeDrawerBtn");
                    const drawer = document.getElementById("sideSettingsDrawer");
                    const overlay = document.getElementById("drawerOverlay");

                    if (gearBtn && drawer && overlay) {
                        const openDrawer = function () {
                            drawer.classList.add("open");
                            overlay.classList.add("open");
                            document.body.style.overflow = "hidden";
                        };

                        const closeDrawer = function () {
                            drawer.classList.remove("open");
                            overlay.classList.remove("open");
                            document.body.style.overflow = "";
                        };

                        gearBtn.addEventListener("click", openDrawer);
                        if (closeBtn) {
                            closeBtn.addEventListener("click", closeDrawer);
                        }
                        overlay.addEventListener("click", closeDrawer);

                        document.addEventListener("keydown", function (e) {
                            if (e.key === "Escape" && drawer.classList.contains("open")) {
                                closeDrawer();
                            }
                        });
                    }
                });
        </script>
    }

    <!-- POPUP CONTAINER FRAME -->
    <div id="globalLogoutModalBox" class="logout-modal-overlay">
        <div class="logout-modal-card">
            <div class="logout-modal-icon">
                <i class="fa-solid fa-right-from-bracket"></i>
            </div>
            <p class="logout-modal-title">Logging Out?</p>
            <p class="logout-modal-text">Are you sure you want to log out?</p>
            <div class="logout-modal-actions">
                <button class="logout-btn-action logout-btn-cancel" onclick="dismissLogoutModal()">Cancel</button>
                <button class="logout-btn-action logout-btn-confirm" onclick="confirmLogoutPostback()">Log Out</button>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <footer class="site-footer">
        <div class="footer-inner">
            <div>
                <strong>Klaw By Krys</strong><br />
                Your boutique nail studio for creative & quality nail sets.<br />
            </div>

            <div class="footer-center">
                <a class="footer-btn" href="#">Follow on Instagram</a>
            </div>

            <div class="footer-right">
                <b>Studio Location</b><br />
                123 Creative Lane<br />
                Studio City, SC 12345
            </div>
        </div>

        <div class="footer-bottom">
            Made with ♥ by Klaw By Krys © 2026
        </div>
    </footer>

    <script>
        function triggerLogoutConfirmation(event) {
        event.preventDefault();

        const drawer = document.getElementById("sideSettingsDrawer");
        const overlay = document.getElementById("drawerOverlay");
        if(drawer && drawer.classList.contains("open")) {
        drawer.classList.remove("open");
        overlay.classList.remove("open");
        document.body.style.overflow = "";
        }

        document.getElementById("globalLogoutModalBox").classList.add("show");
        }

        function dismissLogoutModal() {
        document.getElementById("globalLogoutModalBox").classList.remove("show");
        }

        function confirmLogoutPostback() {
        document.getElementById("logoutForm").submit();
        }
    </script>

    <script src="~/js/cart-popup.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>