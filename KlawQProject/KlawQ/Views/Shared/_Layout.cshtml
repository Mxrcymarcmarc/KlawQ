<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Klaw By Krys</title>
    <link rel="stylesheet" href="/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Shadows+Into+Light+Two&family=Indie+Flower&family=Caveat:wght@400;700&family=Kalam:wght@300;400&display=swap">
    <link href="https://fonts.googleapis.com/css2?family=Shadows+Into+Light+Two&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    @RenderSection("Styles", required: false)
</head>
<body>
    <nav>
        <div class="nav-container">
            <a class="nav-brand" asp-controller="Home" asp-action="Index">🎀 Klaw By Krys</a>
            @if (ViewData["HideNavbar"] == null)
                {
                    <ul class="nav-links">
                        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a href="#gallery">Gallery</a></li>
                        <li><a href="#bookmarks">My Bookmarks</a></li>
                        <li><a asp-controller="Appointment" asp-action="Index">Appointment</a></li>
                        <li><a href="/Account/Logout" onclick="event.preventDefault(); document.getElementById('logoutForm').submit();">Logout</a></li>
                    </ul>
                }
            </div>
    </nav>

    <main role="main" class="main-content">
        @RenderBody()
    </main>

    <form id="logoutForm" action="/Account/Logout" method="post" style="display:none;"></form>

    <footer class="site-footer">
        <div class="footer-inner">
            <div>
                <strong>Klaw By Krys</strong><br />
                Your boutique nail studio for creative & quality nail sets.<br />
            </div>

            <div class="footer-center">
                <a class="footer-btn" href="#">Follow on Instagram</a>
            </div>

            <div class="footer-right">
                <b>Studio Location</b><br />
                123 Creative Lane<br />
                Studio City, SC 12345
            </div>
        </div>

        <div class="footer-bottom">
            Made with ♥ by Klaw By Krys © 2026
        </div>
    </footer>
