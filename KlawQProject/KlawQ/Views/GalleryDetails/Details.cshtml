@model KlawQ.Models.Products

@{
    ViewData["Title"] = Model.Product_Name;
    var mainImg = Model.Product_Image as string;
    if (string.IsNullOrWhiteSpace(mainImg)) mainImg = Url.Content("~/images/placeholder.png");
    else if (mainImg.StartsWith("~")) mainImg = Url.Content(mainImg);
    else if (!mainImg.StartsWith("/")) mainImg = Url.Content("~/" + mainImg.TrimStart('/'));
    else mainImg = Url.Content(mainImg);

    if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
    {
        ViewData["NavbarMode"] = "none";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/nail-works.css" />
    <style>
        .back-dash-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #795548;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
            transition: all 0.2s;
            font-family: 'Montserrat', sans-serif;
        }
        .back-dash-link:hover {
            color: #5d4037;
            transform: translateX(-3px);
            text-decoration: none;
        }

        .details-container {
            max-width: 1200px;
            margin: 24px auto;
            padding: 0 12px;
        }
        .details-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 28px;
            align-items: stretch;
        }
        .image-card {
            background: #fff;
            border-radius: 16px;
            overflow: hidden;
            border: 6px solid #fde6ea;
            box-shadow: 0 8px 18px rgba(0,0,0,.06);
        }
        .image-card img {
            width: 100%;
            aspect-ratio: 1;
            object-fit: cover;
            display: block;
        }
        .info-card {
            background: #fff;
            border-radius: 16px;
            padding: 24px 32px; /* Adjusted padding to reduce top/bottom spaces */
            border: 6px solid #fde6ea;
            box-shadow: 0 8px 18px rgba(0,0,0,.06);
            display: flex;
            flex-direction: column;
            justify-content: flex-start; /* Changed from center to top-aligned */
            box-sizing: border-box;
            height: 100%;
        }
        .product-title {
            font-family: var(--primary-font);
            font-size: 2.2rem; /* Reduced from 3rem */
            color: var(--text-dark-brown);
            margin: 0;
            text-align: center;
            font-weight: normal;
            line-height: 1.2;
        }
        .divider {
            border: 0;
            border-top: 1px solid var(--border-pink);
            margin: 14px 0;
            height: 0;
            width: 100%;
        }
        .desc-wrap {
            flex-grow: 1; /* Expand description wrap to fill middle space */
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 8px 0;
        }
        .desc {
            color: var(--text-brown);
            font-family: var(--secondary-font);
            font-size: 1rem;
            line-height: 1.8;
            margin: 0;
            text-align: center;
            padding: 0 8px;
        }
        .price-section {
            text-align: center;
            margin: 8px 0;
        }
        .price-label {
            font-family: var(--secondary-font);
            color: var(--text-brown);
            font-size: 0.95rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            display: block;
            margin-bottom: 4px;
            opacity: 0.8;
        }
        .price-amount {
            color: #e2557a;
            font-family: var(--secondary-font);
            font-weight: 700;
            font-size: 2.4rem;
            display: block;
        }
        .action-buttons {
            display: flex;
            flex-direction: column;
            gap: 12px;
            width: 100%;
            align-items: center;
        }
        .btn-action-row {
            display: flex;
            gap: 12px;
            align-items: center;
            width: 100%;
        }
        .btn-details-primary {
            flex-grow: 1;
            height: 48px;
            border-radius: 24px;
            background-color: var(--accent-green);
            color: #fff;
            font-family: var(--secondary-font);
            font-weight: 600;
            font-size: 1rem;
            border: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            cursor: pointer;
            transition: background-color 0.2s, transform 0.2s;
            box-shadow: 0 4px 15px rgba(167, 196, 125, 0.4);
            text-decoration: none;
        }
        .btn-details-primary:hover {
            background: var(--accent-green-hover, #92b068);
            transform: translateY(-3px);
            color: #fff;
            text-decoration: none;
        }
        .btn-details-primary:active {
            transform: scale(0.98);
        }
        
        /* Quantity selector styles */
        .qty-controller {
            display: inline-flex;
            align-items: center;
            justify-content: space-between;
            height: 48px;
            width: 130px;
            border-radius: 24px;
            background-color: var(--accent-pink-light);
            border: 2px solid var(--border-pink);
            padding: 0 6px;
            flex-shrink: 0;
            box-sizing: border-box;
        }
        .qty-control-btn {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            border: none;
            background-color: #fff;
            color: var(--text-brown);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 0.9rem;
            transition: background-color 0.2s, transform 0.1s;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }
        .qty-control-btn:hover {
            background-color: var(--border-pink);
            color: #fff;
        }
        .qty-control-btn:active {
            transform: scale(0.9);
        }
        .qty-display {
            width: 44px;
            border: none;
            background: transparent;
            font-family: var(--secondary-font);
            font-weight: 700;
            font-size: 1.05rem;
            text-align: center;
            color: var(--text-dark-brown);
            pointer-events: none;
            -moz-appearance: textfield;
        }
        .qty-display::-webkit-outer-spin-button,
        .qty-display::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        /* Override absolute favorite-btn from nail-works.css to sit inline next to main buttons */
        .btn-heart.favorite-btn {
            position: static !important;
            top: auto !important;
            right: auto !important;
            width: 48px;
            height: 48px;
            border-radius: 50%;
            border: 3px solid var(--border-pink);
            background: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            cursor: pointer;
            box-shadow: 0 2px 6px rgba(0,0,0,.08);
            transition: transform 0.2s ease, border-color 0.2s;
            flex-shrink: 0;
            box-sizing: border-box;
            margin: 0 !important;
        }
        .btn-heart.favorite-btn:hover {
            transform: scale(1.08) !important;
            border-color: #e2557a !important;
        }
        .btn-heart.favorite-btn:active {
            transform: scale(0.92) !important;
        }
        
        .btn-heart .heart-hollow {
            color: #e2557a;
            display: inline;
        }
        .btn-heart .heart-filled {
            color: #e2557a;
            display: none;
        }
        .btn-heart.favorited .heart-hollow {
            display: none;
        }
        .btn-heart.favorited .heart-filled {
            display: inline;
        }

        @@keyframes heartPop {
            0% { transform: scale(0.5); }
            100% { transform: scale(1); }
        }
        .fav-pop {
            animation: heartPop 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .you-may-section {
            margin: 36px 0 20px;
        }
        .you-may-text {
            font-family: var(--primary-font);
            font-size: 2.4rem;
            color: var(--text-dark-brown);
            text-align: center;
            margin-bottom: 16px;
        }
        .related-row {
            display: flex;
            gap: 14px;
            overflow-x: auto;
            padding: 8px 4px;
            scrollbar-width: none;
        }
        .related-row::-webkit-scrollbar {
            display: none;
        }
        .related-card {
            width: 140px;
            height: 105px;
            border-radius: 12px;
            overflow: hidden;
            flex: 0 0 140px;
            background: #fff;
            border: 4px solid #fde6ea;
            box-shadow: 0 6px 14px rgba(0,0,0,.06);
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .related-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .related-card:hover {
            border-color: #f0b8cc;
            box-shadow: 0 8px 18px rgba(0,0,0,.1);
        }

        @@media (max-width:768px) {
            .details-row {
                grid-template-columns: 1fr;
                gap: 20px;
            }
            .info-card {
                padding: 24px;
                min-height: auto;
            }
            .product-title {
                font-size: 2.4rem;
            }
        }
    </style>
}

<div class="details-container">
    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
    {
        <a href="/Gallery" class="back-dash-link">
            <i class="fas fa-arrow-left"></i> Back to Gallery
        </a>
    }
    <div class="details-row">
        <!-- Left card: Image -->
        <div class="image-card">
            <img src="@mainImg" alt="@Model.Product_Name" />
        </div>

        <!-- Right card: Product info -->
        <div class="info-card">
            <h1 class="product-title">@Model.Product_Name</h1>
            <hr class="divider" />

            <div class="desc-wrap">
                <p class="desc">@Model.Product_Description</p>
            </div>

            <hr class="divider" />

            <div class="price-section">
                <span class="price-label">Price</span>
                <span class="price-amount">₱@Model.Product_Price</span>
            </div>

            <hr class="divider" />

            <div class="action-buttons">
                @if (Model.Product_Type != null && Model.Product_Type.ToLower().Contains("original"))
                {
                    <div class="btn-action-row">
                        <a href="/Appointment?Inspiration_Image=@Uri.EscapeDataString(mainImg)&Inspiration_Title=@Uri.EscapeDataString(Model.Product_Name)&Price=@Model.Product_Price" class="btn-details-primary">Book Appointment</a>

                        <button type="button" class="favorite-btn btn-heart @(((ViewData["IsFavorited"] as bool?)==true) ? "favorited" : "")" data-id="@Model.ProductID" aria-label="Toggle favorite">
                            <i class="fa-regular fa-heart heart-hollow"></i>
                            <i class="fa-solid fa-heart heart-filled"></i>
                        </button>
                    </div>
                }
                else if (Model.Product_Type != null && Model.Product_Type.ToLower().Contains("press"))
                {
                    <div class="btn-action-row">
                        <a href="/Order/CheckoutStandard?productId=@Model.ProductID" class="btn-details-primary">Buy Now</a>

                        <button type="button" class="favorite-btn btn-heart @(((ViewData["IsFavorited"] as bool?)==true) ? "favorited" : "")" data-id="@Model.ProductID" aria-label="Toggle favorite">
                            <i class="fa-regular fa-heart heart-hollow"></i>
                            <i class="fa-solid fa-heart heart-filled"></i>
                        </button>
                    </div>

                    <div class="btn-action-row">
                        <button class="btn-details-primary" data-id="@Model.ProductID" id="addCartBtn">
                            <i class="fas fa-cart-plus"></i> Add to Cart
                        </button>

                        <div class="qty-controller">
                            <button type="button" class="qty-control-btn" id="qty-minus" aria-label="Decrease quantity">
                                <i class="fas fa-minus"></i>
                            </button>
                            <input type="number" id="addQty" min="1" value="1" readonly class="qty-display" />
                            <button type="button" class="qty-control-btn" id="qty-plus" aria-label="Increase quantity">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="btn-action-row">
                        <a href="/Appointment?Inspiration_Image=@Uri.EscapeDataString(mainImg)&Inspiration_Title=@Uri.EscapeDataString(Model.Product_Name)&Price=@Model.Product_Price" class="btn-details-primary">Book Appointment</a>

                        <button type="button" class="favorite-btn btn-heart @(((ViewData["IsFavorited"] as bool?)==true) ? "favorited" : "")" data-id="@Model.ProductID" aria-label="Toggle favorite">
                            <i class="fa-regular fa-heart heart-hollow"></i>
                            <i class="fa-solid fa-heart heart-filled"></i>
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- You May Also Like section -->
    @{
        var related = ViewBag.RelatedProducts as List<KlawQ.Models.Products> ?? new List<KlawQ.Models.Products>();
        if (related.Any(x => x.ProductID != Model.ProductID))
        {
            <div class="you-may-section">
                <div class="you-may-text">You May Also Like</div>
                <div class="related-row">
                    @foreach (var r in related.Where(x => x.ProductID != Model.ProductID))
                    {
                        var rimg = r.Product_Image as string;
                        if (string.IsNullOrWhiteSpace(rimg)) rimg = Url.Content("~/images/placeholder.png");
                        else if (rimg.StartsWith("~")) rimg = Url.Content(rimg);
                        else if (!rimg.StartsWith("/")) rimg = Url.Content("~/" + rimg.TrimStart('/'));
                        else rimg = Url.Content(rimg);

                        <a href="@Url.Action("Details", "Gallery", new { id = r.ProductID })" class="related-card">
                            <img src="@rimg" alt="@r.Product_Name" />
                        </a>
                    }
                </div>
            </div>
        }
    }
</div>

@* Hidden antiforgery token for AJAX favorite toggle *@
<form style="display:none">@Html.AntiForgeryToken()</form>

@section Scripts {
    <script src="~/js/nail-works-favs.js"></script>
    <script src="~/js/gallery-details-cart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const qtyMinus = document.getElementById("qty-minus");
            const qtyPlus = document.getElementById("qty-plus");
            const qtyInput = document.getElementById("addQty");

            if (qtyMinus && qtyPlus && qtyInput) {
                qtyMinus.addEventListener("click", function () {
                    let val = parseInt(qtyInput.value) || 1;
                    if (val > 1) {
                        qtyInput.value = val - 1;
                    }
                });

                qtyPlus.addEventListener("click", function () {
                    let val = parseInt(qtyInput.value) || 1;
                    qtyInput.value = val + 1;
                });
            }
        });
    </script>
}

