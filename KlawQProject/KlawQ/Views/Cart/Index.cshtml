@model KlawQ.Models.Cart
@{
    ViewData["Title"] = "Cart";
}
<link rel="stylesheet" href="/css/site.css" />
<div style="max-width:900px;margin:28px auto">
    <h2>Your Cart</h2>
    @if(Model == null || Model.Items == null || !Model.Items.Any()){
        <p>Your cart is empty.</p>
    } else {
        <table style="width:100%"><thead><tr><th>Image</th><th>Name</th><th>Qty</th><th>Price</th></tr></thead><tbody>
        @foreach(var it in Model.Items){
            <tr><td><img src="@it.Product?.Product_Image" style="height:60px;"/></td><td>@it.Product?.Product_Name</td><td>@it.Quantity</td><td>@it.Product?.Product_Price</td></tr>
        }
        </tbody></table>
    }
</div>