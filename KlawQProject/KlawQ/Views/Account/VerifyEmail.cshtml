@model KlawQ.Models.VerifyCodeViewModel
@section Styles {
    <link rel="stylesheet" href="~/css/verify.css" />
}

@{
    ViewData["NavbarMode"] = "none";
}

<div class="verify-container">
    <div class="verify-box">
        <p class="heading">Verify Email</p>
        <p class="description">We sent a 6-digit code to <strong>@Model.Email</strong>. Enter it below to complete registration.</p>

        <form class="verify-email" asp-action="VerifyEmail" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Email" />

            <input asp-for="Code" class="input-field text-center"
                   placeholder="123456" maxlength="6" autocomplete="off" required />
            <span asp-validation-for="Code" class="text-danger"></span>

            <button type="submit" class="btn">Verify & Register</button>

            <p>
              Didn’t receive a code?
              <a href="#" id="resendLink">Resend</a>
            </p>

            <p id="statusMsg"></p>
        </form>

        <p><a href="/Account/Register">Back to Registration</a></p>
    </div>
</div>

@section Scripts {
    <script>
    let cooldown = 60; // seconds
    let canResend = true;

    const resendLink = document.getElementById("resendLink");
    const statusMsg = document.getElementById("statusMsg");

    resendLink.addEventListener("click", async function (e) {
        e.preventDefault();

        if (!canResend) return;

        canResend = false;
        resendLink.style.pointerEvents = "none";

        statusMsg.innerText = "Sending new code...";

        try {
            // Call backend API (change URL depending on your setup)
            const response = await fetch("/Account/ResendCode", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                }
            });

            if (response.ok) {
                statusMsg.innerText = "New code sent!";
            } else {
                statusMsg.innerText = "Failed to resend code.";
            }

        } catch (err) {
            statusMsg.innerText = "Error sending request.";
        }

        // Start cooldown timer
        let timeLeft = cooldown;

        const interval = setInterval(() => {
            resendLink.innerText = `Resend (${timeLeft}s)`;

            timeLeft--;

            if (timeLeft < 0) {
                clearInterval(interval);
                canResend = true;
                resendLink.style.pointerEvents = "auto";
                resendLink.innerText = "Resend";
                statusMsg.innerText = "";
            }
        }, 1000);
    });
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}