@model KlawQ.Models.VerifyCodeViewModel
@section Styles {
    <link rel="stylesheet" href="~/css/login.css" />
}

@{
    ViewData["HideNavbar"] = true;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h3>Email Verification</h3>
                </div>
                <div class="card-body">
                    <p class="text-muted text-center">
                        We sent a 6-digit verification code to <strong>@Model.Email</strong>.
                        Please enter it below to complete your registration.
                    </p>

                    <form asp-action="VerifyEmail" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <input type="hidden" asp-for="Email" />

                        <div class="form-group mb-4">
                            <label asp-for="Code" class="form-label font-weight-bold"></label>
                            <input asp-for="Code" class="form-control text-center tracking-widest"
                                   placeholder="123456" maxlength="6" autocomplete="off" required />
                            <span asp-validation-for="Code" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg">Verify & Register</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center">
                    <a asp-action="Register" class="text-decoration-none">Back to Registration</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}