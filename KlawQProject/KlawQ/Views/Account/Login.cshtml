@model KlawQ.Models.LoginViewModel

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Log in</title>
    <style>
        :root{
            --bg-pink: #fff5f6;     /* page background */
            --panel-pink: #fdeef0;  /* input and panel accents */
            --accent-pink:#fde0e2;  /* circle placeholder */
            --brand-brown: #8b4b3b; /* headings */
            --footer-brown: #6b4228; /* footer background */
            --cta-green: #88b04b;   /* login button */
        }
        body { margin:0; font-family: "Segoe UI", Roboto, Arial; background: linear-gradient(90deg, var(--bg-pink) 0%, #fff9fb 100%); color:var(--brand-brown); }
        .login-container { max-width:900px; margin:40px auto; display:flex; background:#fff; border-radius:8px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,.06); }
        .left { padding:40px; flex:1; background:linear-gradient(#fff,var(--bg-pink)); }
        .right { flex:1; padding:40px; background:#f9f0f2; display:flex; flex-direction:column; align-items:center; justify-content:center; }
        h1 { font-family: 'Segoe Script', cursive; color:var(--brand-brown); font-size:36px; margin:0 0 20px; }
        .input-field { width:100%; padding:12px 16px; margin:8px 0 16px; border-radius:14px; border: none; background:var(--panel-pink); box-sizing:border-box; }
        .btn { background:var(--cta-green); color:white; padding:10px 24px; border-radius:20px; border:none; cursor:pointer; }
        .right .logo-circle{ width:120px;height:120px;background:var(--accent-pink);border-radius:50%;margin:0 auto 12px; }
        .right h2{ color:var(--brand-brown); margin:8px 0; }
        .right p{ color:rgba(139,75,59,0.85); text-align:center; max-width:240px; }
        .brown-box{ background:var(--footer-brown); color:#fff; padding:18px 24px; margin:40px auto 60px; border-radius:8px; display:flex; align-items:center; justify-content:space-between; max-width:1000px; }
        .footer-left{ display:flex; flex-direction:column; }
        .brand{ font-weight:700; }
        .instagram-btn{ background:#fff; color:var(--footer-brown); padding:8px 14px; border-radius:20px; text-decoration:none; font-weight:600; }
        .studio-location{ text-align:right; font-size:14px; }
        a { color:#2f6fb2; text-decoration:none; }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="left">
            <h1>Welcome Back!</h1>
            <p>Enter your Username & Password</p>
            <form asp-action="Login" method="post">
                <input asp-for="Email" class="input-field" type="email" placeholder="Email" />
                <input asp-for="Password" class="input-field" placeholder="Password" type="password" />
                <div>
                    <label><input asp-for="RememberMe" /> Remember me</label>
                </div>
                <button class="btn" type="submit">Log In</button>
            </form>
            <p>Don't have an account? <a href="#">Register here</a></p>
        </div>
        <div class="right">
            <div style="text-align:center;">
                <div class="logo-circle"></div>
                <h2>Klaw By Krys</h2>
                <p>Quality You Can See, Creativity You Can Wear.</p>
            </div>
        </div>
    </div>

    <div class="brown-box">
        <div class="footer-left">
            <div class="brand">Klaw By Krys</div>
            <div class="tagline">Quality You Can See, Creativity You Can Wear.</div>
        </div>
        <div class="footer-center">
            <a class="instagram-btn" href="#" target="_blank" rel="noopener">Follow on Instagram</a>
        </div>
        <div class="studio-location">
            <div>Studio Location</div>
            <div>123 Creative Lane<br/>Studio City, SC 12345</div>
        </div>
    </div>

    <div style="text-align:center; color:rgba(0,0,0,0.45); margin-bottom:30px;">Made with ♥ by Klaw By Krys © 2026</div>
</body>
</html>
