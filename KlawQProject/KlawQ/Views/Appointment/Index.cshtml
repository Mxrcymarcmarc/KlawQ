@model KlawQ.Models.Appointment

@{
    ViewData["Title"] = "Book Appointment";
}

<style>
    :root {
        --bg-pink: #fff5f6;
        --panel-pink: #fdeef0;
        --accent-pink: #fde0e2;
        --brand-brown: #8b4b3b;
        --footer-brown: #6b4228;
        --cta-green: #88b04b;
    }

    body {
        background: var(--bg-pink);
    }

    .appointment-wrap {
        max-width: 1000px !important;
        margin: 0 auto !important;
        padding: 10px 20px;
        box-sizing: border-box;
        width: 100% !important;
    }

    .top-header {
        text-align: center;
        margin-bottom: 18px;
    }

        .top-header h1 {
            font-family: 'Shadows Into Light Two', cursive;
            font-size: 48px;
            color: var(--brand-brown);
            margin-bottom: 6px;
        }

        .top-header p {
            color: #8a6a62;
            margin-bottom: 22px;
        }

    .service-card {
        background: var(--panel-pink);
        border-radius: 12px;
        padding: 18px;
        box-shadow: 0 10px 25px rgba(0,0,0,.06);
        border: 1px solid var(--accent-pink);
        width: 95%;
        max-width: 100%;
    }

    .service-options {
        display: flex;
        gap: 18px;
    }

    .service-box {
        flex: 1;
        padding: 16px;
        border-radius: 8px;
        background: #fff;
        border: 2px solid transparent;
        box-shadow: 0 6px 14px rgba(0,0,0,.04);
        cursor: pointer;
    }

        .service-box.selected {
            border-color: var(--brand-brown);
        }

        .service-box h4 {
            margin-bottom: 8px;
            color: var(--brand-brown);
        }

        .service-box p {
            color: #8a6a62;
            font-size: 13px;
        }

    .info-card {
        background: var(--panel-pink);
        margin-top: 28px;
        border-radius: 12px;
        padding: 22px;
        box-shadow: 0 10px 25px rgba(0,0,0,.06);
        border: 1px solid var(--accent-pink);
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
    }

    .input {
        display: flex;
        flex-direction: column;
    }

        .input label {
            font-size: 13px;
            color: #7a5046;
            margin-bottom: 6px;
        }

        .input input, .input textarea, .input select {
            padding: 12px;
            border-radius: 8px;
            border: 1px solid rgba(139,75,59,0.08);
            background: #fff;
            font-family: "Segoe UI", Roboto, Arial;
            font-size: 14px;
        }

        .input textarea {
            min-height: 100px;
            resize: none;
        }

    .proceed {
        text-align: center;
        margin-top: 28px;
        width: 100%;
    }

    .btn-proceed {
        background: var(--cta-green);
        color: #fff;
        padding: 12px 46px;
        border-radius: 28px;
        border: none;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 6px 12px rgba(136,176,75,0.18);
        transition: all 0.25s ease;
    }
        .btn-proceed:hover {
            background: #6fa03f !important;
            color: white !important;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(0,0,0,0.15);
        }

    /* Modal */
    .modal.hidden {
        display: none !important;
    }

    .overlay {
        position: fixed;
        inset: 0;
        backdrop-filter: blur(8px);
        background: rgba(0,0,0,0.35);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 50;
    }

    .modal-box {
        display: flex;
        gap: 24px;
        max-width: 1000px;
        width: 90%;
    }

    .modal-frame {
        background: var(--panel-pink);
        border-radius: 12px;
        padding: 24px;
        border: 2px solid rgba(139,75,59,0.1);
        flex: 1;
        position: relative;
    }

        .modal-frame h4 {
            color: var(--brand-brown);
            margin-bottom: 12px;
            font-size: 16px;
        }

        .modal-frame p {
            color: #8a6a62;
            font-size: 13px;
            margin-bottom: 16px;
        }

    /* Back button — inside top-left of the left card */
    .btn-back {
        background: none;
        border: none;
        color: var(--brand-brown);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 5px;
        opacity: 0.65;
        padding: 0;
        margin-bottom: 14px;
    }

        .btn-back:hover {
            opacity: 1;
        }

    /* Calendar */
    .calendar-month {
        text-align: center;
        color: var(--brand-brown);
        font-weight: 600;
        margin-bottom: 12px;
    }
    /* Always 6 rows × 7 cols — height never changes between months */
    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7,1fr);
        grid-template-rows: repeat(6, 1fr);
        gap: 8px;
        height: 252px;
    }

    .day {
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        background: #fff;
        border: 1px solid var(--accent-pink);
        cursor: pointer;
        font-size: 14px;
        color: var(--brand-brown);
    }

        .day:hover {
            background: var(--accent-pink);
        }

        .day.unavailable {
            opacity: 0.3;
            cursor: not-allowed;
            background: #f0f0f0;
        }

        .day.selected {
            background: var(--cta-green);
            color: #fff;
            border-color: var(--cta-green);
        }

        .day.empty {
            background: transparent;
            border-color: transparent;
            pointer-events: none;
        }

    /* Time slots */
    .slot-btn {
        display: block;
        width: 100%;
        padding: 12px;
        margin-bottom: 10px;
        border-radius: 8px;
        border: 1px solid rgba(139,75,59,0.1);
        background: #fff;
        cursor: pointer;
        color: var(--brand-brown);
    }

        .slot-btn:hover {
            background: var(--accent-pink);
        }

        .slot-btn.selected {
            background: var(--cta-green);
            color: #fff;
            border-color: var(--cta-green);
        }

        .slot-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

    .calendar-nav {
        background: var(--accent-pink);
        border: none;
        padding: 6px 12px;
        border-radius: 4px;
        cursor: pointer;
        margin: 0 4px;
    }

    /* Day-of-week header labels */
    .dow-header {
        display: grid;
        grid-template-columns: repeat(7,1fr);
        gap: 8px;
        margin-bottom: 4px;
    }

        .dow-header span {
            text-align: center;
            font-size: 11px;
            font-weight: 700;
            color: var(--brand-brown);
            opacity: 0.6;
            text-transform: uppercase;
        }

    /* Right panel: flex column so button stays pinned to bottom */
    .time-panel {
        display: flex;
        flex-direction: column;
    }

    .time-slots-scroll {
        flex: 1;
        overflow-y: auto;
        max-height: 260px;
        padding-right: 4px;
    }

    .modal-action {
        text-align: center;
        margin-top: 16px;
        flex-shrink: 0;
    }

    .btn-book {
        background: var(--cta-green);
        color: #fff;
        padding: 12px 40px;
        border-radius: 24px;
        border: none;
        font-weight: 600;
        cursor: pointer;
    }

    /* Prevent background scroll when modal is open */
    body.modal-open {
        overflow: hidden;
    }

    @@media(max-width:1000px) {
        .modal-box {
            flex-direction: column;
        }

        .info-grid {
            grid-template-columns: 1fr;
        }

        .service-options {
            flex-direction: column;
        }
    }
</style>

<div class="appointment-wrap">
    <div class="top-header">
        <h1>Book your appointment!</h1>
        <p>Choose your service, pick your add-ons, and let's create something beautiful together!</p>
    </div>

    <div class="service-card">
        <h3 style="color:var(--brand-brown); margin-bottom:12px;">✦ Select Your Service</h3>
        <div class="service-options">
            <div class="service-box selected" id="box-studio">
                <h4>Studio-based Service</h4>
                <p>Ideal for those who want a focused professional environment with our complete suite of equipment.</p>
            </div>
            <div class="service-box" id="box-home">
                <h4>Home Service</h4>
                <p>The ultimate convenience for busy schedules, perfect for staying cozy while we handle the details.</p>
            </div>
        </div>
    </div>

    <form id="appointmentForm">
        <div class="info-card">
            <h3 style="color:var(--brand-brown); margin-bottom:12px;">✦ Your Information</h3>
            <div class="info-grid" id="studioFields">
                <div class="input">
                    <label>Full Name *</label>
                    <input id="fullName" name="Full_Name" type="text" placeholder="Jane Doe" />
                </div>
                <div class="input">
                    <label>Email *</label>
                    <input id="email" name="Social_Account" type="email" placeholder="jane@example.com" />
                </div>
                <div class="input">
                    <label>Phone *</label>
                    <input id="phone" name="Phone" type="text" placeholder="(555) 123-4567" />
                </div>
                <div class="input">
                    <label>Design Reference (Image) *</label>
                    <input id="designImage" name="DesignImage" type="file" accept="image/*" />
                </div>
                <div class="input" style="grid-column:1 / -1">
                    <label>Special Requests</label>
                    <textarea id="notes" name="Additional_Notes" placeholder="Tell me about your dream nail design ..."></textarea>
                </div>
            </div>

            <div class="info-grid" id="homeFields" style="display:none;">
                <div class="input">
                    <label>Full Name *</label>
                    <input id="h-fullName" type="text" placeholder="Jane Doe" />
                </div>
                <div class="input">
                    <label>Email *</label>
                    <input id="h-email" type="email" placeholder="jane@example.com" />
                </div>
                <div class="input">
                    <label>Phone *</label>
                    <input id="h-phone" type="text" placeholder="(555) 123-4567" />
                </div>
                <div class="input">
                    <label>Design Reference (Image) *</label>
                    <input id="designImage" name="DesignImage" type="file" accept="image/*" />
                </div>
                <div class="input">
                    <label>Address *</label>
                    <input id="h-address" type="text" placeholder="123 Main St" />
                </div>  
                <div class="input" style="grid-column:1 / -1">
                    <label>Special Requests</label>
                    <textarea id="h-notes" placeholder="Tell me about your dream nail design ..."></textarea>
                </div>
            </div>
        </div>

        <div class="proceed">
            <button type="button" class="btn-proceed" id="proceedBtn">Proceed</button>
        </div>
    </form>
</div>

<!-- Modal: Date & Time Selection -->
<div id="bookingModal" class="modal hidden">
    <div class="overlay">
        <div class="modal-box">
            <!-- Left: Calendar -->
            <div class="modal-frame">
                <!-- Back button inside the card, top left -->
                <button type="button" class="btn-back" id="closeBookingModal">&#8592; Back</button>
                <h4>1. Select Date</h4>
                <p>Select a specific date on the calendar slot to reserve appointment schedule.</p>
                <div class="calendar-month" id="calendarMonthLabel">June 2026</div>
                <!-- Day-of-week labels -->
                <div class="dow-header">
                    <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span>
                    <span>Thu</span><span>Fri</span><span>Sat</span>
                </div>
                <div class="calendar-grid" id="calendarGrid">Loading...</div>
                <div style="text-align:center; margin-top:12px; display:flex; justify-content:center; gap:8px;">
                    <button type="button" class="calendar-nav" id="prevMonth">← Prev</button>
                    <button type="button" class="calendar-nav" id="nextMonth">Next →</button>
                </div>
            </div>

            <!-- Right: Time Slots — flex column keeps button pinned at bottom -->
            <div class="modal-frame time-panel">
                <h4>2. Appointment Time</h4>
                <p id="selectedDateDisplay">Available time slot as of mm/dd/yyyy (Current Date)</p>
                <p style="color:var(--brand-brown); font-weight:600; margin-bottom:12px;">Select your preferred time slot *</p>
                <div id="timeSlots" class="time-slots-scroll">Select a date to see available times</div>
                <div class="modal-action">
                    <button type="button" class="btn-book" id="confirmBooking" disabled>Proceed to Payment</button>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- Modal: Payment Confirmation -->
<div id="paymentModal" class="modal hidden">
    <div class="overlay">
        <div class="modal-box" style="max-width:500px;">
            <div class="modal-frame" style="flex:unset; width:100%;">
                <h4>Payment Required</h4>
                <p style="margin-bottom:16px;">A downpayment of <strong>₱150.00</strong> is required to confirm your appointment.</p>
                <div style="background:#fff; padding:16px; border-radius:8px; margin-bottom:16px; text-align:center;">
                    <p style="color:#7a5046; margin-bottom:8px;">Downpayment Amount</p>
                    <p style="font-size:28px; color:var(--brand-brown); font-weight:700;">₱150.00</p>
                </div>
                <div class="modal-action" style="display:flex; gap:12px; justify-content:center;">
                    <button type="button" class="btn-book" id="payNow">Pay Now</button>
                    <button type="button" style="background:#ccc; color:#333; padding:12px 40px; border-radius:24px; border:none; font-weight:600; cursor:pointer;" id="cancelPayment">Cancel</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Service box toggle
        document.getElementById('box-studio').addEventListener('click', () => {
        document.getElementById('box-studio').classList.add('selected');
        document.getElementById('box-home').classList.remove('selected');
        document.getElementById('studioFields').style.display = 'grid';
        document.getElementById('homeFields').style.display = 'none';
    });

        document.getElementById('box-home').addEventListener('click', () => {
        document.getElementById('box-home').classList.add('selected');
        document.getElementById('box-studio').classList.remove('selected');
        document.getElementById('studioFields').style.display = 'none';
        document.getElementById('homeFields').style.display = 'grid';
    });

        let selectedDate = null;
        let selectedSlotHour = null;
        let selectedSlotDate = null;
        let selectedSlotTime = null;
        let currentMonth = new Date();
        let allDays = [];
        let tempAppointmentData = null;

        // Store form data temporarily (don't save yet)
        async function validateAndStoreFormData() {
            const isHome = document.getElementById('box-home').classList.contains('selected');

            const fullName = isHome
                ? document.getElementById('h-fullName').value.trim()
                : document.getElementById('fullName').value.trim();
            const email = isHome
                ? document.getElementById('h-email').value.trim()
                : document.getElementById('email').value.trim();
            const phone = isHome
                ? document.getElementById('h-phone').value.trim()
                : document.getElementById('phone').value.trim();
            const notes = isHome
                ? document.getElementById('h-notes').value
                : document.getElementById('notes').value;

            if (!fullName) { alert('Full Name is required'); return false; }
            if (!email)    { alert('Email is required');     return false; }
            if (!phone)    { alert('Phone is required');     return false; }

            if (isHome) {
                const address = document.getElementById('h-address').value.trim();
                if (!address) { alert('Address is required'); return false; }

                tempAppointmentData = {
                    Full_Name: fullName,
                    Social_Account: email,
                    Phone: phone,
                    Additional_Notes: notes,
                    Down_Payment_Paid: false,
                    Appointment_Type: 'H',
                    Status: 0,
                    Inspiration_Image: null
                };
            } else {
                const fileInput = document.getElementById('designImage');
                const file = fileInput.files[0];
                if (!file) { alert('Design Reference image is required'); return false; }
                if (file.size > 2 * 1024 * 1024) {
                    alert('Image must be smaller than 2MB.');
                    return false;
                }

                const imageBase64 = await new Promise((resolve) => {
                    const reader = new FileReader();
                    reader.onload = (e) => resolve(e.target.result);
                    reader.readAsDataURL(file);
                });

                tempAppointmentData = {
                    Full_Name: fullName,
                    Social_Account: email,
                    Phone: phone,
                    Additional_Notes: notes,
                    Down_Payment_Paid: false,
                    Appointment_Type: 'S',
                    Status: 0,
                    Inspiration_Image: imageBase64
                };
            }

            return true;
        }

        // Create appointment in database (called only after payment confirmation)
        async function createAppointment() {
            if (!tempAppointmentData) {
                alert('Form data not found. Please try again.');
                return null;
            }

            const res = await fetch('/Appointment/create-json', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(tempAppointmentData)
            });

            if (!res.ok) {
                const errorData = await res.json().catch(() => ({}));
                alert('Failed to create appointment:\n' + (errorData.error || 'Unknown error'));
                return null;
            }

            const json = await res.json();
            return json.AppId;
        }

        // Proceed button: validate form then show calendar (don't save yet)
        document.getElementById('proceedBtn').addEventListener('click', async () => {
            const isValid = await validateAndStoreFormData();
            if (!isValid) return;

            document.getElementById('bookingModal').classList.remove('hidden');
            document.body.classList.add('modal-open'); // lock background scroll

            // Reset currentMonth to a fresh Date object (not mutated)
            currentMonth = new Date();
            currentMonth.setDate(1); // Normalize to 1st to avoid month-overflow issues

            await loadCalendar();
        });

        async function loadCalendar() {
            const res = await fetch('/api/calendar/current-view-status');
            allDays = await res.json();
            renderCalendar();
        }

        function renderCalendar() {
            const grid = document.getElementById('calendarGrid');
            grid.innerHTML = '';

            const year  = currentMonth.getFullYear();
            const month = currentMonth.getMonth(); // 0-based

            document.getElementById('calendarMonthLabel').innerText =
                currentMonth.toLocaleDateString(undefined, { month: 'long', year: 'numeric' });

            const firstDayOfWeek = new Date(year, month, 1).getDay();
            const daysInMonth    = new Date(year, month + 1, 0).getDate();
            const TOTAL_CELLS    = 42; // always 6 rows × 7 cols — fixed height

            for (let cell = 0; cell < TOTAL_CELLS; cell++) {
                const dayNumber = cell - firstDayOfWeek + 1;
                const el = document.createElement('div');

                if (dayNumber < 1 || dayNumber > daysInMonth) {
                    // Empty filler cell — takes space but shows nothing
                    el.className = 'day empty';
                } else {
                    const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(dayNumber).padStart(2, '0')}`;
                    const dayData = allDays.find(d => (d.DateString || d.dateString) === dateStr);
                    const isAvailable = dayData?.IsAvailable ?? dayData?.isAvailable ?? false;

                    el.className = 'day' + (isAvailable ? '' : ' unavailable');
                    el.innerText = dayNumber;

                    el.addEventListener('click', () => {
                        if (!isAvailable) return;
                        selectDate(dateStr, el);
                    });
                }

                grid.appendChild(el);
            }

            // Collect all valid month keys (e.g. "2026-06") from allDays, ignoring undefined entries
            const validDays = allDays.filter(d => d && (d.DateString || d.dateString));
            const monthKeys = [...new Set(validDays.map(d => (d.DateString || d.dateString).substring(0, 7)))].sort();
            const currentKey = `${year}-${String(month + 1).padStart(2, '0')}`;

            // Disable Prev if we are already on the earliest available month
            document.getElementById('prevMonth').disabled =
                monthKeys.length === 0 || monthKeys[0] === currentKey;

            // Disable Next if we are already on the latest available month
            document.getElementById('nextMonth').disabled =
                monthKeys.length === 0 || monthKeys[monthKeys.length - 1] === currentKey;
        }

        async function selectDate(dateStr, element) {
            document.querySelectorAll('.day.selected').forEach(d => d.classList.remove('selected'));
            element.classList.add('selected');

            selectedDate    = dateStr;
            selectedSlotHour = null;
            document.getElementById('confirmBooking').disabled = true;

            // Parse date parts manually to avoid UTC-midnight timezone shift
            const [y, m, d] = dateStr.split('-').map(Number);
            const localDate = new Date(y, m - 1, d); // Local time, no UTC offset issue
            document.getElementById('selectedDateDisplay').innerText =
                `Available time slot as of ${localDate.toLocaleDateString()} (Current Date)`;

            const res   = await fetch('/api/calendar/day-slots-status?chosenDate=' + dateStr);
            const slots = await res.json();

            const container = document.getElementById('timeSlots');
            container.innerHTML = '';

            if (!slots || slots.length === 0) {
                container.innerText = 'No available slots for this date.';
                return;
            }

            slots.forEach(s => {
                const btn = document.createElement('button');
                btn.className = 'slot-btn';
                btn.type      = 'button';
                // Support both PascalCase and camelCase from the API
                const formattedTime = s.FormattedTime ?? s.formattedTime;
                const isAvailable   = s.IsAvailable   ?? s.isAvailable   ?? false;
                const slotHour      = s.SlotHour       ?? s.slotHour;
                btn.innerText = formattedTime;

                if (!isAvailable) {
                    btn.disabled = true;
                } else {
                    btn.addEventListener('click', () => {
                        document.querySelectorAll('.slot-btn').forEach(x => x.classList.remove('selected'));
                        btn.classList.add('selected');
                        selectedSlotHour = slotHour;
                        document.getElementById('confirmBooking').disabled = false;
                    });
                }

                container.appendChild(btn);
            });
        }

        document.getElementById('prevMonth').addEventListener('click', () => {
            currentMonth = new Date(currentMonth.getFullYear(), currentMonth.getMonth() - 1, 1);
            renderCalendar();
        });

        document.getElementById('nextMonth').addEventListener('click', () => {
            currentMonth = new Date(currentMonth.getFullYear(), currentMonth.getMonth() + 1, 1);
            renderCalendar();
        });

        document.getElementById('confirmBooking').addEventListener('click', () => {
            if (!selectedDate || selectedSlotHour == null) {
                alert('Please select both a date and time slot');
                return;
            }

            selectedSlotDate = selectedDate;
            selectedSlotTime = selectedSlotHour;

            document.getElementById('bookingModal').classList.add('hidden');
            document.getElementById('paymentModal').classList.remove('hidden');
        });

        document.getElementById('payNow').addEventListener('click', async () => {
            if (!tempAppointmentData) {
                alert('Error: Form data not found');
                return;
            }

            const appointmentId = await createAppointment();
            if (!appointmentId) return;

            // Send explicit +08:00 offset so the server always receives PH time correctly
            const dateISO = selectedSlotDate + 'T00:00:00+08:00';
            const timeISO = selectedSlotDate + 'T' + String(selectedSlotTime).padStart(2, '0') + ':00:00+08:00';

            const booking = {
                AppId: appointmentId,
                Appointment_Date: dateISO,
                Time_Slot: timeISO
            };

            const bookingRes = await fetch('/api/calendar/booking', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(booking)
            });

            if (!bookingRes.ok) {
                const msg = await bookingRes.text();
                alert('Booking failed: ' + msg);
                return;
            }

            const updateRes = await fetch(`/Appointment/UpdateDownPayment?id=${appointmentId}`, { method: 'POST' });
            if (updateRes.ok) {
                alert('✓ Downpayment recorded! Your appointment has been confirmed.');
                document.getElementById('paymentModal').classList.add('hidden');
                document.body.classList.remove('modal-open');
                tempAppointmentData = null;
                location.href = '/Home/Index';
            } else {
                alert('Error recording payment. Please try again.');
            }
        });

        document.getElementById('cancelPayment').addEventListener('click', () => {
            document.getElementById('paymentModal').classList.add('hidden');
            document.getElementById('bookingModal').classList.remove('hidden');
        });

        document.getElementById('closeBookingModal').addEventListener('click', () => {
            document.getElementById('bookingModal').classList.add('hidden');
            document.body.classList.remove('modal-open'); // restore background scroll
        });
    </script>
}
